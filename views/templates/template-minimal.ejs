<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= brand.name %></title>
    <link rel="icon" type="image/jpeg" href="<%= brand.logo_url || '/favicon.jpg' %>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        primary: '<%= brand.primary_color || "#6366f1" %>',
                        'primary-hover': '<%= brand.primary_hover_color || "#4f46e5" %>'
                    }
                }
            }
        }
    </script>
</head>
<body class="font-sans antialiased text-slate-900 dark:text-white bg-white dark:bg-black transition-colors duration-300 min-h-screen">
    <script>
        if (localStorage.getItem('darkMode') === 'true' || (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
    <% var navLinksList = typeof navLinks !== 'undefined' ? navLinks : []; %>
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-black/80 backdrop-blur-md border-b border-slate-100 dark:border-slate-800">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex items-center justify-between h-20">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-9 w-auto">
                    <% } else { %>
                        <div class="h-9 w-9 rounded-full flex items-center justify-center font-semibold text-white text-lg" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-semibold text-lg tracking-tight"><%= brand.name %></span>
                </div>
                
                <nav class="hidden md:flex items-center gap-8">
                    <% navLinksList.forEach(link => { %>
                        <% if (link.is_button) { %>
                            <a href="<%= link.href %>" class="px-5 py-2.5 rounded-full font-medium text-white transition-opacity hover:opacity-80" style="background: <%= brand.primary_color %>">
                                <%= link.label %>
                            </a>
                        <% } else { %>
                            <a href="<%= link.href %>" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                                <%= link.label %>
                            </a>
                        <% } %>
                    <%}); %>
                </nav>
                
                <button onclick="toggleDarkMode()" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    <span id="dark-icon" class="material-icons text-slate-600 dark:text-yellow-400">dark_mode</span>
                    <span id="light-icon" class="material-icons text-slate-600 hidden">light_mode</span>
                </button>
            </div>
        </div>
    </header>

    <main class="pt-20">
        <% var hero = typeof sections !== 'undefined' && sections.hero ? sections.hero : {}; %>
        <% var hasHero = hero.badge || hero.heading_line1 || hero.heading_line2 || hero.description; %>
        <% if (hasHero) { %>
        <!-- Hero Section -->
        <section class="min-h-[85vh] flex items-center justify-center py-32">
            <div class="max-w-6xl mx-auto px-6 <%= hero.hero_image_url ? 'grid grid-cols-1 md:grid-cols-2 gap-16 items-center text-left' : 'text-center max-w-3xl' %>">
                <div class="<%= hero.hero_image_url ? '' : 'mx-auto' %>">
                    <% if (hero.badge) { %>
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-100 dark:bg-slate-800 mb-10">
                        <span class="w-1.5 h-1.5 rounded-full" style="background: <%= brand.primary_color %>"></span>
                        <span class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase tracking-wider"><%= hero.badge %></span>
                    </div>
                    <% } %>
                    
                    <% if (hero.heading_line1) { %>
                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tight text-slate-900 dark:text-white mb-6 leading-[1.1]">
                        <%= hero.heading_line1 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.heading_line2) { %>
                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tight mb-8 leading-[1.1]" style="color: <%= brand.primary_color %>">
                        <%= hero.heading_line2 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.description) { %>
                    <p class="text-lg text-slate-500 dark:text-slate-400 mb-12 <%= hero.hero_image_url ? 'max-w-md' : 'max-w-xl mx-auto' %> leading-relaxed">
                        <%= hero.description %>
                    </p>
                    <% } %>
                    
                    <div class="flex flex-wrap <%= hero.hero_image_url ? 'justify-start' : 'justify-center' %> gap-4">
                        <% if (hero.cta_primary_text) { %>
                        <a href="<%= hero.cta_primary_href || '#' %>" class="px-8 py-4 rounded-full font-medium text-white transition-opacity hover:opacity-80" style="background: <%= brand.primary_color %>">
                            <%= hero.cta_primary_text %>
                        </a>
                        <% } %>
                        <% if (hero.cta_secondary_text) { %>
                        <a href="<%= hero.cta_secondary_href || '#' %>" class="px-8 py-4 rounded-full font-medium border border-slate-200 dark:border-slate-700 hover:border-slate-300 dark:hover:border-slate-600 transition-colors">
                            <%= hero.cta_secondary_text %>
                        </a>
                        <% } %>
                    </div>
                </div>

                <% if (hero.hero_image_url) { %>
                <div class="mt-16 md:mt-0 relative">
                    <div class="absolute inset-0 bg-slate-100 dark:bg-slate-800 rounded-3xl transform translate-x-4 translate-y-4"></div>
                    <img src="<%= hero.hero_image_url %>" alt="<%= hero.heading_line1 %>" class="relative z-10 w-full max-w-md mx-auto rounded-3xl shadow-xl">
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var featuresHeader = typeof sections !== 'undefined' && sections.features_header ? sections.features_header : {}; %>
        <% var featuresList = typeof features !== 'undefined' ? features : []; %>
        <% if (featuresHeader.heading || featuresList.length > 0) { %>
        <!-- Features Section -->
        <section class="py-32">
            <div class="max-w-6xl mx-auto px-6">
                <div class="text-center mb-20">
                    <% if (featuresHeader.heading) { %>
                    <h2 class="text-3xl md:text-4xl font-semibold text-slate-900 dark:text-white mb-4 tracking-tight">
                        <%= featuresHeader.heading %>
                        <% if (featuresHeader.heading_highlight) { %>
                        <span style="color: <%= brand.primary_color %>"><%= featuresHeader.heading_highlight %></span>
                        <% } %>
                    </h2>
                    <% } %>
                    <% if (featuresHeader.description) { %>
                    <p class="text-slate-500 dark:text-slate-400 max-w-lg mx-auto"><%= featuresHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (featuresList.length > 0) { %>
                <div class="grid md:grid-cols-3 gap-12">
                    <% featuresList.forEach((feature, i) => { %>
                    <div class="text-center">
                        <div class="w-14 h-14 mx-auto mb-6 rounded-2xl flex items-center justify-center" style="background: <%= brand.primary_color %>10">
                            <span class="material-icons text-2xl" style="color: <%= brand.primary_color %>"><%= feature.icon || 'star' %></span>
                        </div>
                        <h3 class="text-lg font-medium text-slate-900 dark:text-white mb-2"><%= feature.title %></h3>
                        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= feature.description %></p>
                    </div>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var catalogHeader = typeof sections !== 'undefined' && sections.catalog_header ? sections.catalog_header : {}; %>
        <% var productsList = typeof products !== 'undefined' ? products : []; %>
        <% if (catalogHeader.heading || productsList.length > 0) { %>
        <!-- Products Section -->
        <section class="py-32 border-t border-slate-100 dark:border-slate-800">
            <div class="max-w-6xl mx-auto px-6">
                <div class="text-center mb-20">
                    <% if (catalogHeader.heading) { %>
                    <h2 class="text-3xl md:text-4xl font-semibold text-slate-900 dark:text-white mb-4 tracking-tight"><%= catalogHeader.heading %></h2>
                    <% } %>
                    <% if (catalogHeader.description) { %>
                    <p class="text-slate-500 dark:text-slate-400"><%= catalogHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (productsList.length > 0) { %>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    <% productsList.forEach(product => { %>
                    <a href="<%= product.product_url || '#' %>" target="<%= product.product_url ? '_blank' : '_self' %>" class="block group">
                        <div class="aspect-[3/4] relative overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-800 mb-4">
                            <% if (product.image_url) { %>
                            <img src="<%= product.image_url %>" alt="<%= product.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                            <% } else { %>
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-icons text-4xl text-slate-300 dark:text-slate-600">image</span>
                            </div>
                            <% } %>
                            <% if (product.grade) { %>
                            <span class="absolute top-3 left-3 px-3 py-1 rounded-full text-xs font-medium text-white" style="background: <%= brand.primary_color %>"><%= product.grade %></span>
                            <% } %>
                        </div>
                        <h3 class="font-medium text-slate-900 dark:text-white mb-1"><%= product.title %></h3>
                        <% if (product.price) { %>
                        <p class="font-medium" style="color: <%= brand.primary_color %>">Rp <%= typeof product.price === 'number' ? product.price.toLocaleString('id-ID') : product.price %></p>
                        <% } %>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var cta = typeof sections !== 'undefined' && sections.cta ? sections.cta : {}; %>
        <% if (cta.heading_prefix || cta.heading_highlight || cta.button1_text) { %>
        <!-- CTA Section -->
        <section class="py-32 border-t border-slate-100 dark:border-slate-800">
            <div class="max-w-2xl mx-auto px-6 text-center">
                <% if (cta.heading_prefix || cta.heading_highlight) { %>
                <h2 class="text-3xl md:text-4xl font-semibold text-slate-900 dark:text-white mb-6 tracking-tight">
                    <%= cta.heading_prefix || '' %> <span style="color: <%= brand.primary_color %>"><%= cta.heading_highlight || '' %></span>
                </h2>
                <% } %>
                <% if (cta.description) { %>
                <p class="text-slate-500 dark:text-slate-400 mb-10"><%= cta.description %></p>
                <% } %>
                <% if (cta.button1_text) { %>
                <a href="#" class="inline-block px-10 py-4 rounded-full font-medium text-white transition-opacity hover:opacity-80" style="background: <%= brand.primary_color %>">
                    <%= cta.button1_text %>
                </a>
                <% } %>
            </div>
        </section>
        <% } %>
    </main>

    <% var footerLinksList = typeof footerLinks !== 'undefined' ? footerLinks : []; %>
    <% var socialLinksList = typeof socialLinks !== 'undefined' ? socialLinks : []; %>
    <% if (footerLinksList.length > 0 || socialLinksList.length > 0 || brand.copyright_text) { %>
    <!-- Footer -->
    <footer class="py-16 border-t border-slate-100 dark:border-slate-800">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex flex-wrap justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-7">
                    <% } else { %>
                        <div class="h-7 w-7 rounded-full flex items-center justify-center font-semibold text-white" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-semibold text-sm"><%= brand.name %></span>
                </div>
                
                <% if (footerLinksList.length > 0) { %>
                <div class="flex flex-wrap gap-8">
                    <% footerLinksList.forEach(link => { %>
                    <a href="<%= link.href %>" class="text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors"><%= link.label %></a>
                    <% }); %>
                </div>
                <% } %>
                
                <% if (socialLinksList.length > 0) { %>
                <div class="flex gap-2">
                    <% socialLinksList.forEach(social => { %>
                    <a href="<%= social.href %>" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-icons text-sm text-slate-500 dark:text-slate-400"><%= social.icon %></span>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
            
            <% if (brand.copyright_text) { %>
            <div class="mt-10 pt-8 text-center text-xs text-slate-400 dark:text-slate-500">
                <%= brand.copyright_text %>
            </div>
            <% } %>
        </div>
    </footer>
    <% } %>

    <script>
        function toggleDarkMode() {
            const html = document.documentElement;
            const isDark = html.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
            
            const darkIcon = document.getElementById('dark-icon');
            const lightIcon = document.getElementById('light-icon');
            
            if (isDark) {
                darkIcon.classList.add('hidden');
                lightIcon.classList.remove('hidden');
            } else {
                darkIcon.classList.remove('hidden');
                lightIcon.classList.add('hidden');
            }
        }
        
        if (document.documentElement.classList.contains('dark')) {
            document.getElementById('dark-icon').classList.add('hidden');
            document.getElementById('light-icon').classList.remove('hidden');
        }
    </script>
</body>
</html>
