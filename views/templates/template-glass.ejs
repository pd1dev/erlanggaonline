<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= brand.name %></title>
    <link rel="icon" type="image/jpeg" href="<%= brand.logo_url || '/favicon.jpg' %>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        primary: '<%= brand.primary_color || "#6366f1" %>',
                        'primary-hover': '<%= brand.primary_hover_color || "#4f46e5" %>'
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.3);
            --glass-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
        }
        .dark {
            --glass-bg: rgba(17, 24, 39, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
        }
        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
        }
        .glass-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }
        .dark .glass-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body class="font-sans transition-colors duration-300 bg-gradient-to-br from-slate-50 via-white to-slate-100 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 min-h-screen">
    <script>
        // Dark mode init
        if (localStorage.getItem('darkMode') === 'true' || (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
    <% var navLinksList = typeof navLinks !== 'undefined' ? navLinks : []; %>
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 glass">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-10 w-auto rounded-lg">
                    <% } else { %>
                        <div class="h-10 w-10 rounded-xl flex items-center justify-center font-bold text-white text-xl" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-bold text-xl text-slate-800 dark:text-white"><%= brand.name %></span>
                </div>
                
                <nav class="hidden md:flex items-center gap-6">
                    <% navLinksList.forEach(link => { %>
                        <% if (link.is_button) { %>
                            <a href="<%= link.href %>" class="px-5 py-2.5 rounded-full font-semibold text-white transition-all hover:opacity-90" style="background: <%= brand.primary_color %>">
                                <%= link.label %>
                            </a>
                        <% } else { %>
                            <a href="<%= link.href %>" class="text-slate-600 dark:text-slate-300 hover:text-primary font-medium transition-colors">
                                <%= link.label %>
                            </a>
                        <% } %>
                    <%}); %>
                </nav>
                
                <!-- Dark Mode Toggle -->
                <button onclick="toggleDarkMode()" class="p-2.5 rounded-full glass-card hover:scale-110 transition-transform">
                    <span id="dark-icon" class="material-icons text-slate-700 dark:text-yellow-400">dark_mode</span>
                    <span id="light-icon" class="material-icons text-yellow-500 hidden">light_mode</span>
                </button>
            </div>
        </div>
    </header>

    <main class="pt-16">
        <% var hero = typeof sections !== 'undefined' && sections.hero ? sections.hero : {}; %>
        <% var hasHero = hero.badge || hero.heading_line1 || hero.heading_line2 || hero.description; %>
        <% if (hasHero) { %>
        <!-- Hero Section -->
        <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
            <!-- Animated Background -->
            <div class="absolute inset-0 overflow-hidden">
                <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-pulse" style="background: <%= brand.primary_color %>20"></div>
                <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-pulse" style="animation-delay: 2s; background: <%= brand.primary_color %>30"></div>
            </div>
            
            <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 <%= hero.hero_image_url ? 'grid grid-cols-1 lg:grid-cols-2 gap-12 items-center text-left' : 'text-center max-w-5xl' %>">
                <div class="<%= hero.hero_image_url ? '' : 'mx-auto' %>">
                    <% if (hero.badge) { %>
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8">
                        <span class="w-2 h-2 rounded-full animate-pulse" style="background: <%= brand.primary_color %>"></span>
                        <span class="text-sm font-semibold text-slate-700 dark:text-slate-300"><%= hero.badge %></span>
                    </div>
                    <% } %>
                    
                    <% if (hero.heading_line1) { %>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-slate-800 dark:text-white mb-6 leading-tight">
                        <%= hero.heading_line1 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.heading_line2) { %>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold mb-6 leading-tight bg-gradient-to-r from-violet-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent">
                        <%= hero.heading_line2 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.description) { %>
                    <p class="text-xl text-slate-600 dark:text-slate-300 mb-10 <%= hero.hero_image_url ? 'max-w-xl' : 'max-w-2xl mx-auto' %> leading-relaxed">
                        <%= hero.description %>
                    </p>
                    <% } %>
                    
                    <div class="flex flex-wrap <%= hero.hero_image_url ? 'justify-start' : 'justify-center' %> gap-4">
                        <% if (hero.cta_primary_text) { %>
                        <a href="<%= hero.cta_primary_href || '#' %>" class="px-8 py-4 rounded-full font-bold text-white shadow-2xl hover:shadow-primary/50 hover:scale-105 transition-all" style="background: <%= brand.primary_color %>">
                            <%= hero.cta_primary_text %>
                        </a>
                        <% } %>
                        <% if (hero.cta_secondary_text) { %>
                        <a href="<%= hero.cta_secondary_href || '#' %>" class="px-8 py-4 rounded-full font-bold glass hover:scale-105 transition-all text-slate-700 dark:text-white">
                            <%= hero.cta_secondary_text %>
                        </a>
                        <% } %>
                    </div>
                </div>

                <% if (hero.hero_image_url) { %>
                <div class="relative mt-12 lg:mt-0">
                    <div class="glass-card rounded-[3rem] p-4 transform lg:rotate-3 hover:rotate-0 transition-transform duration-500">
                        <img src="<%= hero.hero_image_url %>" alt="<%= hero.heading_line1 %>" class="w-full max-w-lg mx-auto rounded-[2rem] shadow-lg">
                    </div>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var featuresHeader = typeof sections !== 'undefined' && sections.features_header ? sections.features_header : {}; %>
        <% var featuresList = typeof features !== 'undefined' ? features : []; %>
        <% if (featuresHeader.heading || featuresList.length > 0) { %>
        <!-- Features Section -->
        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <% if (featuresHeader.heading) { %>
                    <h2 class="text-4xl md:text-5xl font-bold text-slate-800 dark:text-white mb-4">
                        <%= featuresHeader.heading %>
                        <% if (featuresHeader.heading_highlight) { %>
                        <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent"><%= featuresHeader.heading_highlight %></span>
                        <% } %>
                    </h2>
                    <% } %>
                    <% if (featuresHeader.description) { %>
                    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto"><%= featuresHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (featuresList.length > 0) { %>
                <div class="grid md:grid-cols-3 gap-8">
                    <% featuresList.forEach((feature, i) => { %>
                    <div class="glass-card rounded-3xl p-8 text-center hover:scale-105 transition-transform duration-300">
                        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl flex items-center justify-center" style="background: <%= brand.primary_color %>20">
                            <span class="material-icons text-3xl" style="color: <%= brand.primary_color %>"><%= feature.icon || 'star' %></span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 dark:text-white mb-3"><%= feature.title %></h3>
                        <p class="text-slate-600 dark:text-slate-400"><%= feature.description %></p>
                    </div>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var catalogHeader = typeof sections !== 'undefined' && sections.catalog_header ? sections.catalog_header : {}; %>
        <% var productsList = typeof products !== 'undefined' ? products : []; %>
        <% if (catalogHeader.heading || productsList.length > 0) { %>
        <!-- Products Section -->
        <section class="py-24 relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <% if (catalogHeader.heading) { %>
                    <h2 class="text-4xl md:text-5xl font-bold text-slate-800 dark:text-white mb-4"><%= catalogHeader.heading %></h2>
                    <% } %>
                    <% if (catalogHeader.description) { %>
                    <p class="text-lg text-slate-600 dark:text-slate-400"><%= catalogHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (productsList.length > 0) { %>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <% productsList.forEach(product => { %>
                    <a href="<%= product.product_url || '#' %>" target="<%= product.product_url ? '_blank' : '_self' %>" class="block glass-card rounded-3xl overflow-hidden group hover:scale-105 transition-all duration-300">
                        <div class="aspect-[3/4] relative overflow-hidden">
                            <% if (product.image_url) { %>
                            <img src="<%= product.image_url %>" alt="<%= product.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            <% } else { %>
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-700">
                                <span class="material-icons text-6xl text-slate-300 dark:text-slate-600">image</span>
                            </div>
                            <% } %>
                            <% if (product.grade) { %>
                            <span class="absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-bold text-white shadow-lg" style="background: <%= brand.primary_color %>"><%= product.grade %></span>
                            <% } %>
                        </div>
                        <div class="p-5">
                            <h3 class="font-bold text-lg text-slate-800 dark:text-white mb-1"><%= product.title %></h3>
                            <% if (product.price) { %>
                            <p class="font-bold text-xl" style="color: <%= brand.primary_color %>">Rp <%= typeof product.price === 'number' ? product.price.toLocaleString('id-ID') : product.price %></p>
                            <% } %>
                        </div>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var cta = typeof sections !== 'undefined' && sections.cta ? sections.cta : {}; %>
        <% if (cta.heading_prefix || cta.heading_highlight || cta.button1_text) { %>
        <!-- CTA Section -->
        <section class="py-24 relative overflow-hidden">
            <div class="absolute inset-0 glass"></div>
            <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <% if (cta.heading_prefix || cta.heading_highlight) { %>
                <h2 class="text-4xl md:text-5xl font-bold text-slate-800 dark:text-white mb-6">
                    <%= cta.heading_prefix || '' %> <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent"><%= cta.heading_highlight || '' %></span>
                </h2>
                <% } %>
                <% if (cta.description) { %>
                <p class="text-lg text-slate-600 dark:text-slate-300 mb-10"><%= cta.description %></p>
                <% } %>
                <% if (cta.button1_text) { %>
                <a href="#" class="inline-block px-10 py-5 rounded-full font-bold text-white shadow-2xl hover:scale-110 transition-all" style="background: <%= brand.primary_color %>">
                    <%= cta.button1_text %>
                </a>
                <% } %>
            </div>
        </section>
        <% } %>
    </main>

    <% var footerLinksList = typeof footerLinks !== 'undefined' ? footerLinks : []; %>
    <% var socialLinksList = typeof socialLinks !== 'undefined' ? socialLinks : []; %>
    <% if (footerLinksList.length > 0 || socialLinksList.length > 0 || brand.copyright_text) { %>
    <!-- Footer -->
    <footer class="py-12 glass">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-wrap justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-8 rounded">
                    <% } else { %>
                        <div class="h-8 w-8 rounded-lg flex items-center justify-center font-bold text-white" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-bold text-slate-800 dark:text-white"><%= brand.name %></span>
                </div>
                
                <% if (footerLinksList.length > 0) { %>
                <div class="flex flex-wrap gap-6">
                    <% footerLinksList.forEach(link => { %>
                    <a href="<%= link.href %>" class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors"><%= link.label %></a>
                    <% }); %>
                </div>
                <% } %>
                
                <% if (socialLinksList.length > 0) { %>
                <div class="flex gap-3">
                    <% socialLinksList.forEach(social => { %>
                    <a href="<%= social.href %>" class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:scale-110 transition-transform">
                        <span class="material-icons text-sm text-slate-600 dark:text-slate-400"><%= social.icon %></span>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
            
            <% if (brand.copyright_text) { %>
            <div class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-700 text-center text-slate-500 dark:text-slate-400 text-sm">
                <%= brand.copyright_text %>
            </div>
            <% } %>
        </div>
    </footer>
    <% } %>

    <script>
        function toggleDarkMode() {
            const html = document.documentElement;
            const isDark = html.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
            
            const darkIcon = document.getElementById('dark-icon');
            const lightIcon = document.getElementById('light-icon');
            
            if (isDark) {
                darkIcon.classList.add('hidden');
                lightIcon.classList.remove('hidden');
            } else {
                darkIcon.classList.remove('hidden');
                lightIcon.classList.add('hidden');
            }
        }
        
        // Set initial icon state
        if (document.documentElement.classList.contains('dark')) {
            document.getElementById('dark-icon').classList.add('hidden');
            document.getElementById('light-icon').classList.remove('hidden');
        }
    </script>
</body>
</html>
