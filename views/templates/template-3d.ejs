<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= brand.name %></title>
    <link rel="icon" type="image/jpeg" href="<%= brand.logo_url || '/favicon.jpg' %>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Space Grotesk', 'sans-serif'] },
                    colors: {
                        primary: '<%= brand.primary_color || "#6366f1" %>',
                        'primary-hover': '<%= brand.primary_hover_color || "#4f46e5" %>'
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }
        .dark body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        ._3d-card {
            transform-style: preserve-3d;
            transition: transform 0.3s ease;
        }
        ._3d-card:hover {
            transform: translateY(-10px) rotateX(5deg);
        }
        ._3d-button {
            transform: translateZ(0);
            transition: all 0.3s ease;
            box-shadow: 0 4px 0 rgba(0,0,0,0.2);
        }
        ._3d-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 0 rgba(0,0,0,0.2);
        }
        ._3d-button:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0 rgba(0,0,0,0.2);
        }
        .float {
            animation: float 6s ease-in-out infinite;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
        .pulse-3d {
            animation: pulse-3d 2s ease-in-out infinite;
        }
        @keyframes pulse-3d {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
    </style>
</head>
<body class="font-sans min-h-screen">
    <script>
        if (localStorage.getItem('darkMode') === 'true' || (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
    <% var navLinksList = typeof navLinks !== 'undefined' ? navLinks : []; %>
    
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-lg shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-10 w-auto rounded-2xl shadow-lg">
                    <% } else { %>
                        <div class="h-10 w-10 rounded-2xl flex items-center justify-center font-bold text-white text-xl shadow-lg" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-bold text-xl text-slate-800 dark:text-white"><%= brand.name %></span>
                </div>
                
                <nav class="hidden md:flex items-center gap-4">
                    <% navLinksList.forEach(link => { %>
                        <% if (link.is_button) { %>
                            <a href="<%= link.href %>" class="px-6 py-3 rounded-2xl font-bold text-white _3d-button" style="background: <%= brand.primary_color %>">
                                <%= link.label %>
                            </a>
                        <% } else { %>
                            <a href="<%= link.href %>" class="text-slate-600 dark:text-slate-300 hover:text-primary font-semibold transition-colors">
                                <%= link.label %>
                            </a>
                        <% } %>
                    <%}); %>
                </nav>
                
                <button onclick="toggleDarkMode()" class="p-3 rounded-2xl bg-white dark:bg-slate-800 shadow-lg hover:scale-110 transition-transform">
                    <span id="dark-icon" class="material-icons text-slate-700 dark:text-yellow-400">dark_mode</span>
                    <span id="light-icon" class="material-icons text-yellow-500 hidden">light_mode</span>
                </button>
            </div>
        </div>
    </header>

    <main class="pt-16">
        <% var hero = typeof sections !== 'undefined' && sections.hero ? sections.hero : {}; %>
        <% var hasHero = hero.badge || hero.heading_line1 || hero.heading_line2 || hero.description; %>
        <% if (hasHero) { %>
        <!-- Hero Section -->
        <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden py-20">
            <!-- 3D Decorations -->
            <div class="absolute top-20 left-10 w-32 h-32 rounded-3xl bg-gradient-to-br from-violet-500 to-purple-600 opacity-20 float" style="transform: rotate(-15deg)"></div>
            <div class="absolute bottom-20 right-10 w-24 h-24 rounded-3xl bg-gradient-to-br from-indigo-500 to-blue-600 opacity-20 float" style="animation-delay: 2s; transform: rotate(15deg)"></div>
            <div class="absolute top-1/3 right-1/4 w-16 h-16 rounded-2xl bg-gradient-to-br from-pink-500 to-rose-600 opacity-20 float" style="animation-delay: 4s"></div>
            
            <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 <%= hero.hero_image_url ? 'grid grid-cols-1 lg:grid-cols-2 gap-12 items-center text-left' : 'text-center max-w-5xl' %>">
                <div class="<%= hero.hero_image_url ? '' : 'mx-auto' %>">
                    <% if (hero.badge) { %>
                    <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white dark:bg-slate-800 shadow-xl mb-10">
                        <span class="w-2.5 h-2.5 rounded-full pulse-3d" style="background: <%= brand.primary_color %>"></span>
                        <span class="text-sm font-bold text-slate-700 dark:text-slate-300"><%= hero.badge %></span>
                    </div>
                    <% } %>
                    
                    <% if (hero.heading_line1) { %>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-slate-800 dark:text-white mb-6 leading-tight">
                        <%= hero.heading_line1 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.heading_line2) { %>
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-tight bg-gradient-to-r from-violet-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent">
                        <%= hero.heading_line2 %>
                    </h1>
                    <% } %>
                    
                    <% if (hero.description) { %>
                    <p class="text-xl text-slate-600 dark:text-slate-300 mb-12 <%= hero.hero_image_url ? 'max-w-xl' : 'max-w-2xl mx-auto' %> leading-relaxed">
                        <%= hero.description %>
                    </p>
                    <% } %>
                    
                    <div class="flex flex-wrap <%= hero.hero_image_url ? 'justify-start' : 'justify-center' %> gap-5">
                        <% if (hero.cta_primary_text) { %>
                        <a href="<%= hero.cta_primary_href || '#' %>" class="px-10 py-5 rounded-2xl font-bold text-white shadow-2xl hover:scale-105 transition-all _3d-button" style="background: <%= brand.primary_color %>">
                            <%= hero.cta_primary_text %>
                        </a>
                        <% } %>
                        <% if (hero.cta_secondary_text) { %>
                        <a href="<%= hero.cta_secondary_href || '#' %>" class="px-10 py-5 rounded-2xl font-bold bg-white dark:bg-slate-800 shadow-xl hover:scale-105 transition-all _3d-button text-slate-700 dark:text-white">
                            <%= hero.cta_secondary_text %>
                        </a>
                        <% } %>
                    </div>
                </div>

                <% if (hero.hero_image_url) { %>
                <div class="relative mt-12 lg:mt-0">
                    <div class="absolute inset-0 bg-gradient-to-tr from-violet-500 to-purple-500 rounded-[3rem] transform rotate-6 opacity-20 dark:opacity-40 blur-xl"></div>
                    <img src="<%= hero.hero_image_url %>" alt="<%= hero.heading_line1 %>" class="relative z-10 w-full max-w-lg mx-auto rounded-[3rem] shadow-2xl float" style="animation-duration: 6s;">
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var featuresHeader = typeof sections !== 'undefined' && sections.features_header ? sections.features_header : {}; %>
        <% var featuresList = typeof features !== 'undefined' ? features : []; %>
        <% if (featuresHeader.heading || featuresList.length > 0) { %>
        <!-- Features Section -->
        <section class="py-28">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-20">
                    <% if (featuresHeader.heading) { %>
                    <h2 class="text-5xl md:text-6xl font-bold text-slate-800 dark:text-white mb-5">
                        <%= featuresHeader.heading %>
                        <% if (featuresHeader.heading_highlight) { %>
                        <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent"><%= featuresHeader.heading_highlight %></span>
                        <% } %>
                    </h2>
                    <% } %>
                    <% if (featuresHeader.description) { %>
                    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto"><%= featuresHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (featuresList.length > 0) { %>
                <div class="grid md:grid-cols-3 gap-8">
                    <% featuresList.forEach((feature, i) => { %>
                    <div class="bg-white dark:bg-slate-800 rounded-3xl p-10 shadow-2xl _3d-card">
                        <div class="w-20 h-20 rounded-3xl flex items-center justify-center mb-6 shadow-lg" style="background: <%= brand.primary_color %>20">
                            <span class="material-icons text-4xl" style="color: <%= brand.primary_color %>"><%= feature.icon || 'star' %></span>
                        </div>
                        <h3 class="text-2xl font-bold text-slate-800 dark:text-white mb-3"><%= feature.title %></h3>
                        <p class="text-slate-600 dark:text-slate-400"><%= feature.description %></p>
                    </div>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var catalogHeader = typeof sections !== 'undefined' && sections.catalog_header ? sections.catalog_header : {}; %>
        <% var productsList = typeof products !== 'undefined' ? products : []; %>
        <% if (catalogHeader.heading || productsList.length > 0) { %>
        <!-- Products Section -->
        <section class="py-28">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-20">
                    <% if (catalogHeader.heading) { %>
                    <h2 class="text-5xl md:text-6xl font-bold text-slate-800 dark:text-white mb-5"><%= catalogHeader.heading %></h2>
                    <% } %>
                    <% if (catalogHeader.description) { %>
                    <p class="text-lg text-slate-600 dark:text-slate-400"><%= catalogHeader.description %></p>
                    <% } %>
                </div>
                
                <% if (productsList.length > 0) { %>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
                    <% productsList.forEach(product => { %>
                    <a href="<%= product.product_url || '#' %>" target="<%= product.product_url ? '_blank' : '_self' %>" class="block bg-white dark:bg-slate-800 rounded-3xl overflow-hidden shadow-2xl _3d-card group">
                        <div class="aspect-[3/4] relative overflow-hidden">
                            <% if (product.image_url) { %>
                            <img src="<%= product.image_url %>" alt="<%= product.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            <% } else { %>
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-700 dark:to-slate-600">
                                <span class="material-icons text-6xl text-slate-300 dark:text-slate-500">image</span>
                            </div>
                            <% } %>
                            <% if (product.grade) { %>
                            <span class="absolute top-5 left-5 px-4 py-2 rounded-2xl text-sm font-bold text-white shadow-lg" style="background: <%= brand.primary_color %>"><%= product.grade %></span>
                            <% } %>
                        </div>
                        <div class="p-6">
                            <h3 class="font-bold text-xl text-slate-800 dark:text-white mb-2"><%= product.title %></h3>
                            <% if (product.price) { %>
                            <p class="font-bold text-2xl" style="color: <%= brand.primary_color %>">Rp <%= typeof product.price === 'number' ? product.price.toLocaleString('id-ID') : product.price %></p>
                            <% } %>
                        </div>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
        </section>
        <% } %>

        <% var cta = typeof sections !== 'undefined' && sections.cta ? sections.cta : {}; %>
        <% if (cta.heading_prefix || cta.heading_highlight || cta.button1_text) { %>
        <!-- CTA Section -->
        <section class="py-28 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-violet-600 via-indigo-600 to-purple-600"></div>
            <div class="absolute inset-0 opacity-30">
                <div class="absolute top-10 left-10 w-40 h-40 rounded-full bg-white float"></div>
                <div class="absolute bottom-10 right-10 w-32 h-32 rounded-full bg-white float" style="animation-delay: 2s"></div>
            </div>
            
            <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <% if (cta.heading_prefix || cta.heading_highlight) { %>
                <h2 class="text-5xl md:text-6xl font-bold text-white mb-6">
                    <%= cta.heading_prefix || '' %> <span class="text-yellow-300"><%= cta.heading_highlight || '' %></span>
                </h2>
                <% } %>
                <% if (cta.description) { %>
                <p class="text-xl text-white/80 mb-10"><%= cta.description %></p>
                <% } %>
                <% if (cta.button1_text) { %>
                <a href="#" class="inline-block px-14 py-6 rounded-2xl font-bold text-white shadow-2xl hover:scale-110 transition-all _3d-button bg-white" style="color: <%= brand.primary_color %>">
                    <%= cta.button1_text %>
                </a>
                <% } %>
            </div>
        </section>
        <% } %>
    </main>

    <% var footerLinksList = typeof footerLinks !== 'undefined' ? footerLinks : []; %>
    <% var socialLinksList = typeof socialLinks !== 'undefined' ? socialLinks : []; %>
    <% if (footerLinksList.length > 0 || socialLinksList.length > 0 || brand.copyright_text) { %>
    <!-- Footer -->
    <footer class="py-12 bg-white dark:bg-slate-900 shadow-2xl">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-wrap justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <% if (brand.logo_url) { %>
                        <img src="<%= brand.logo_url %>" alt="<%= brand.name %>" class="h-8 rounded-2xl shadow-lg">
                    <% } else { %>
                        <div class="h-8 w-8 rounded-2xl flex items-center justify-center font-bold text-white shadow-lg" style="background: <%= brand.primary_color %>">
                            <%= brand.logo_initial || brand.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                    <span class="font-bold text-slate-800 dark:text-white"><%= brand.name %></span>
                </div>
                
                <% if (footerLinksList.length > 0) { %>
                <div class="flex flex-wrap gap-6">
                    <% footerLinksList.forEach(link => { %>
                    <a href="<%= link.href %>" class="text-slate-600 dark:text-slate-400 hover:text-primary font-medium transition-colors"><%= link.label %></a>
                    <% }); %>
                </div>
                <% } %>
                
                <% if (socialLinksList.length > 0) { %>
                <div class="flex gap-3">
                    <% socialLinksList.forEach(social => { %>
                    <a href="<%= social.href %>" class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 shadow-lg flex items-center justify-center hover:scale-110 transition-transform">
                        <span class="material-icons text-slate-600 dark:text-slate-400"><%= social.icon %></span>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>
            
            <% if (brand.copyright_text) { %>
            <div class="mt-10 pt-8 border-t border-slate-200 dark:border-slate-700 text-center text-slate-500 dark:text-slate-400 text-sm">
                <%= brand.copyright_text %>
            </div>
            <% } %>
        </div>
    </footer>
    <% } %>

    <script>
        function toggleDarkMode() {
            const html = document.documentElement;
            const isDark = html.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
            
            const darkIcon = document.getElementById('dark-icon');
            const lightIcon = document.getElementById('light-icon');
            
            if (isDark) {
                darkIcon.classList.add('hidden');
                lightIcon.classList.remove('hidden');
            } else {
                darkIcon.classList.remove('hidden');
                lightIcon.classList.add('hidden');
            }
        }
        
        if (document.documentElement.classList.contains('dark')) {
            document.getElementById('dark-icon').classList.add('hidden');
            document.getElementById('light-icon').classList.remove('hidden');
        }
    </script>
</body>
</html>
