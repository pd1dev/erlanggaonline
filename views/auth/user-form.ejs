<%- include('../admin/partials/_head', { title: editUser ? 'Edit User - CMS Admin' : 'Add User - CMS Admin' }) %>
<body class="bg-slate-100 font-sans antialiased">
<%- include('../admin/partials/_sidebar', { user, activePage: 'users' }) %>

    <!-- Main Content -->
    <div id="main-content" class="sidebar-transition ml-0 lg:ml-64">
        <%- include('../admin/partials/_header', { title: editUser ? 'Edit User' : 'Add User', user }) %>

        <main class="p-3 lg:p-6 page-enter">
            <div class="flex items-center gap-1.5 lg:gap-2 text-xs lg:text-sm text-slate-500 mb-4 lg:mb-6">
                <a href="/admin" class="hover:text-slate-700">Dashboard</a>
                <span class="material-icons text-xs">chevron_right</span>
                <a href="/auth/users" class="hover:text-slate-700">Users</a>
                <span class="material-icons text-xs">chevron_right</span>
                <span class="text-slate-900 font-medium"><%= editUser ? editUser.username : 'Add User' %></span>
            </div>

            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-3 lg:px-4 py-2 lg:py-3 rounded-lg lg:rounded-xl mb-4 lg:mb-6 flex items-center gap-2 text-xs lg:text-sm">
                    <span class="material-icons text-sm">error</span>
                    <%= error %>
                </div>
            <% } %>

            <form method="POST" action="<%= editUser ? '/auth/users/' + editUser.uuid + '/update' : '/auth/users/create' %>">
                <div class="bg-white rounded-xl lg:rounded-2xl shadow-sm border border-slate-100 p-4 lg:p-6 card-hover">
                    <h2 class="text-base lg:text-lg font-bold text-slate-900 mb-3 lg:mb-4 flex items-center gap-2">
                        <span class="material-icons text-blue-500 text-sm lg:text-base"><%= editUser ? 'edit' : 'person_add' %></span>
                        <%= editUser ? 'Edit User' : 'Add New User' %>
                    </h2>
                    <div class="space-y-3 lg:space-y-4">
                        <div>
                            <label class="block text-xs lg:text-sm font-medium text-slate-700 mb-1">Username</label>
                            <input type="text" name="username" value="<%= editUser ? editUser.username : '' %>" required
                                class="w-full border border-slate-300 rounded-lg px-3 py-2 lg:py-2.5 text-xs lg:text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"
                                placeholder="Masukkan username">
                        </div>
                        <div>
                            <label class="block text-xs lg:text-sm font-medium text-slate-700 mb-1">
                                Password <% if (editUser) { %><span class="text-slate-400 font-normal">(kosongkan jika tidak diubah)</span><% } %>
                            </label>
                            <input type="password" name="password" <%= editUser ? '' : 'required' %>
                                class="w-full border border-slate-300 rounded-lg px-3 py-2 lg:py-2.5 text-xs lg:text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"
                                placeholder="<%= editUser ? 'Biarkan kosong jika tidak diubah' : 'Masukkan password' %>">
                        </div>
                        <div>
                            <label class="block text-xs lg:text-sm font-medium text-slate-700 mb-1">Role</label>
                            <select name="role" class="w-full border border-slate-300 rounded-lg px-3 py-2 lg:py-2.5 text-xs lg:text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500">
                                <option value="admin" <%= editUser && editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                <option value="super_admin" <%= editUser && editUser.role === 'super_admin' ? 'selected' : '' %>>Super Admin</option>
                            </select>
                            <p class="text-xs text-slate-400 mt-1.5">
                                <strong>Admin:</strong> Hanya dapat mengelola brand yang dibuat sendiri.<br>
                                <strong>Super Admin:</strong> Dapat mengelola semua brand dan user.
                            </p>
                        </div>
                    </div>
                    <div class="mt-4 lg:mt-6 flex flex-col sm:flex-row gap-2 sm:gap-3 justify-end">
                        <a href="/auth/users" class="w-full sm:w-auto bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 lg:px-5 py-2 lg:py-2.5 rounded-lg text-xs lg:text-sm font-semibold transition-colors text-center">Batal</a>
                        <button type="submit" class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-4 lg:px-6 py-2 lg:py-2.5 rounded-lg text-xs lg:text-sm font-semibold flex items-center justify-center gap-2 transition-colors shadow-sm">
                            <span class="material-icons text-sm">save</span>
                            <%= editUser ? 'Update User' : 'Create User' %>
                        </button>
                    </div>
                </div>
            </form>
        </main>
    </div>

    <%- include('../admin/partials/_scripts') %>
</body>
</html>
