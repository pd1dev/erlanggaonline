<%- include('../admin/partials/_head', { title: 'Manage Users - CMS Admin' }) %>
<body class="bg-slate-100 font-sans antialiased">
<%- include('../admin/partials/_sidebar', { user, activePage: 'users' }) %>

    <!-- Main Content -->
    <div id="main-content" class="sidebar-transition ml-0 lg:ml-64">
        <%- include('../admin/partials/_header', { title: 'Manage Users', user }) %>

        <main class="p-6 page-enter">
            <div class="flex items-center gap-2 text-sm text-slate-500 mb-6">
                <a href="/admin" class="hover:text-slate-700">Dashboard</a>
                <span class="material-icons text-xs">chevron_right</span>
                <span class="text-slate-900 font-medium">Manage Users</span>
            </div>

            <% if (success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2 text-sm">
                    <span class="material-icons text-sm">check_circle</span>
                    <%= success %>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2 text-sm">
                    <span class="material-icons text-sm">error</span>
                    <%= error %>
                </div>
            <% } %>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-0 mb-4 sm:mb-6">
                <h1 class="text-xl md:text-2xl font-bold text-slate-900">Manage Users</h1>
                <a href="/auth/users/create"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-4 md:px-5 py-2 md:py-2.5 rounded-lg md:rounded-xl text-xs md:text-sm font-semibold flex items-center justify-center gap-2 transition-colors shadow-sm">
                    <span class="material-icons text-sm md:text-base">person_add</span> Add User
                </a>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden card-hover">
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[600px]">
                        <thead class="bg-slate-50 border-b border-slate-100">
                            <tr>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">User</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">Role</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">Brands</th>
                                <th class="px-4 md:px-6 py-3 text-left text-xs font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">Dibuat</th>
                                <th class="px-4 md:px-6 py-3 text-right text-xs font-bold text-slate-500 uppercase tracking-wider whitespace-nowrap">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% users.forEach(u => { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-4 md:px-6 py-3 md:py-4">
                                        <div class="flex items-center gap-2 md:gap-3">
                                            <div class="w-8 h-8 md:w-10 md:h-10 rounded-lg md:rounded-xl flex items-center justify-center font-bold text-white text-xs md:text-sm <%= u.role === 'super_admin' ? 'bg-yellow-500' : 'bg-blue-500' %>">
                                                <%= u.username.charAt(0).toUpperCase() %>
                                            </div>
                                            <div>
                                                <p class="font-semibold text-slate-900 text-xs md:text-sm"><%= u.username %></p>
                                                <% if (u.id === user.id) { %>
                                                    <span class="text-xs text-blue-500 font-medium">(Anda)</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 md:px-6 py-3 md:py-4">
                                        <% if (u.role === 'super_admin') { %>
                                            <span class="inline-flex items-center gap-1 bg-yellow-50 text-yellow-700 px-2 py-0.5 md:py-1 rounded-full text-xs font-bold border border-yellow-200">
                                                <span class="material-icons text-xs">shield</span> <span class="hidden sm:inline">Super Admin</span><span class="sm:hidden">Admin</span>
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1 bg-blue-50 text-blue-700 px-2 py-0.5 md:py-1 rounded-full text-xs font-bold border border-blue-200">
                                                <span class="material-icons text-xs">person</span> Admin
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-4 md:px-6 py-3 md:py-4 text-xs md:text-sm text-slate-600"><%= u.brand_count %> brand</td>
                                    <td class="px-4 md:px-6 py-3 md:py-4 text-xs md:text-sm text-slate-500"><%= new Date(u.created_at).toLocaleDateString('id-ID') %></td>
                                    <td class="px-4 md:px-6 py-3 md:py-4 text-right">
                                        <div class="flex gap-1 md:gap-2 justify-end">
                                            <a href="/auth/users/<%= u.uuid %>/edit" class="bg-blue-50 hover:bg-blue-100 text-blue-600 px-2 md:px-3 py-1 rounded-lg text-xs font-semibold transition-colors">Edit</a>
                                            <% if (u.id !== user.id) { %>
                                                <form method="POST" action="/auth/users/<%= u.uuid %>/delete" onsubmit="return confirm('Hapus user <%= u.username %>?')" class="inline">
                                                    <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-2 md:px-3 py-1 rounded-lg text-xs font-semibold transition-colors">Hapus</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <%- include('../admin/partials/_scripts') %>
</body>
</html>
