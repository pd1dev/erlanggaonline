<%- include('../partials/_head', { title: brand ? 'Edit ' + brand.name : 'Create Brand' }) %>
<body class="bg-slate-100 font-sans antialiased">
<%- include('../partials/_sidebar', { user, activePage: 'brands' }) %>

    <!-- Main Content -->
    <div id="main-content" class="sidebar-transition ml-0 lg:ml-64">
        <%- include('../partials/_header', { title: 'Brands', user }) %>

        <main class="p-3 md:p-6 page-enter">

            <% if (typeof error !=='undefined' && error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-3 md:px-4 py-2 md:py-3 rounded-lg md:rounded-xl mb-4 md:mb-6 flex items-center gap-2 text-sm">
                    <span class="material-icons text-sm">error</span>
                    <%= error %>
                </div>
            <% } %>

            <% if (typeof success !=='undefined' && success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-3 md:px-4 py-2 md:py-3 rounded-lg md:rounded-xl mb-4 md:mb-6 flex items-center gap-2 text-sm">
                    <span class="material-icons text-sm">check_circle</span>
                    <%= success %>
                </div>
            <% } %>

                <!-- Breadcrumb -->
                <div class="flex items-center gap-1.5 md:gap-2 text-xs md:text-sm text-slate-500 mb-4 md:mb-6">
                    <a href="/admin" class="hover:text-slate-700">Dashboard</a>
                    <span class="material-icons text-xs">chevron_right</span>
                    <a href="/admin/brands" class="hover:text-slate-700">Brands</a>
                    <span class="material-icons text-xs">chevron_right</span>
                    <span class="text-slate-900 font-medium">
                        <%= brand ? brand.name : 'New Brand' %>
                    </span>
                </div>

                <h1 class="text-xl md:text-2xl font-bold text-slate-900 mb-4 md:mb-6">
                    <%= brand ? 'Edit: ' + brand.name : 'Create New Brand' %>
                </h1>

                <!-- LAYOUT 2 KOLOM -->
                <div class="flex flex-col lg:flex-row gap-6 items-start">

                <!-- KOLOM 1: Form Editor -->
                <div class="w-full flex-1 min-w-0 flex flex-col">

                        <!-- Tabs -->
                        <% const tabs = [
                            { id: 'brand', label: 'Brand', icon: 'storefront' },
                            { id: 'hero', label: 'Hero', icon: 'view_carousel' },
                            { id: 'features', label: 'Fitur', icon: 'star' },
                            { id: 'cta', label: 'CTA', icon: 'campaign' },
                            { id: 'catalog', label: 'Katalog', icon: 'inventory_2' },
                            { id: 'products', label: 'Produk', icon: 'menu_book' },
                            { id: 'navigation', label: 'Navigasi', icon: 'menu' },
                            { id: 'footer', label: 'Footer', icon: 'copyright' }
                        ]; %>
                        <div class="mb-4 md:mb-6 w-full overflow-hidden">
                            <div class="flex flex-wrap gap-1 bg-gray-100 p-1 rounded-xl w-full">
                                <% tabs.forEach(tab=> { %>
                                    <a href="?tab=<%= tab.id %>"
                                        class="px-3 py-2 rounded-lg text-sm font-medium transition-all whitespace-nowrap flex items-center gap-1.5 <%= activeTab === tab.id ? 'bg-white text-blue-600 shadow-sm ring-1 ring-gray-200' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50' %>">
                                        <span class="material-icons text-sm"><%= tab.icon %></span>
                                        <%= tab.label %>
                                    </a>
                                <%}); %>
                            </div>
                        </div>

                        <% if (activeTab === 'brand') { %>
                        <!-- BRAND SETTINGS -->
                        <form method="POST" enctype="multipart/form-data"
                            action="<%= brand ? '/admin/brands/' + brand.uuid + '/update' : '/admin/brands/create' %>">
                            <!-- Template Selection -->
                            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4">
                                <h2 class="text-base font-bold text-gray-900 mb-3 flex items-center gap-2">
                                    <span class="material-icons text-blue-500 text-sm">dashboard</span> Pilih Template
                                </h2>
                                
                                <!-- Template Cards - 4 Columns -->
                                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 mb-3">
                                    <% templates.forEach((template, idx) => { %>
                                        <div class="template-card bg-gray-50 rounded-lg border-2 border-gray-200 overflow-hidden cursor-pointer transition-all hover:border-blue-300 hover:shadow-sm <%= brand && brand.template_id == template.id ? 'border-blue-500 ring-2 ring-blue-200' : '' %>"
                                            onclick="selectTemplateEdit(<%= template.id %>, '<%= template.file_path %>')"
                                            id="template-card-edit-<%= template.id %>">
                                            <div class="relative aspect-[4/3] <%= ['from-slate-900 via-slate-800 to-slate-900', 'from-blue-900 via-blue-800 to-indigo-900', 'from-emerald-900 via-teal-800 to-cyan-900', 'from-violet-900 via-purple-800 to-fuchsia-900'][idx % 4] %>">
                                                <div class="absolute inset-0.5 p-0.5">
                                                    <div class="w-full h-full bg-white rounded overflow-hidden">
                                                        <div class="h-2 bg-gray-100 flex items-center px-1 gap-0.5">
                                                            <div class="w-1 h-1 rounded-full bg-red-400"></div>
                                                            <div class="w-1 h-1 rounded-full bg-yellow-400"></div>
                                                            <div class="w-1 h-1 rounded-full bg-green-400"></div>
                                                        </div>
                                                        <div class="p-0.5 space-y-0.5">
                                                            <div class="h-1 w-8 bg-gray-300 rounded"></div>
                                                            <div class="h-3 w-full bg-gray-200 rounded"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="selected-check absolute top-0.5 right-0.5 w-4 h-4 <%= brand && brand.template_id == template.id ? 'bg-blue-500' : 'bg-gray-400' %> rounded-full flex items-center justify-center">
                                                    <span class="material-icons text-white text-xs">check</span>
                                                </div>
                                            </div>
                                            <div class="p-1.5 text-center">
                                                <h3 class="font-medium text-xs text-gray-700"><%= template.name %></h3>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                                
                                <input type="hidden" name="template_id" id="selected-template-id-edit" value="<%= brand ? brand.template_id : '' %>">
                            </div>

                            <!-- Brand Settings -->
                            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
                                <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                                    <span class="material-icons text-blue-500">storefront</span> Brand Settings
                                </h2>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Brand Name</label>
                                        <input type="text" name="name" value="<%= brand ? brand.name : '' %>"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500"
                                            required>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">URL Slug</label>
                                        <div class="flex items-center">
                                            <span class="text-gray-400 text-sm mr-1">localhost:3000/</span>
                                            <input type="text" name="slug" value="<%= brand ? brand.slug : '' %>"
                                                class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500"
                                                required pattern="[a-z0-9-]+"
                                                title="Lowercase letters, numbers, and hyphens only">
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Logo Text
                                            (Navbar)</label>
                                        <input type="text" name="logo_text" value="<%= brand ? brand.logo_text : '' %>"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500">
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Logo Initial
                                            (Fallback)</label>
                                        <input type="text" name="logo_initial"
                                            value="<%= brand ? brand.logo_initial : '' %>" maxlength="2"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500"
                                            placeholder="e.g. E">
                                        <p class="text-xs text-gray-400 mt-1">Hanya ditampilkan jika Logo URL kosong</p>
                                    </div>
                                    <div class="md:col-span-2">
                                        <%- include('../components/imageUpload', { 
                                            name: 'logo', 
                                            existingUrl: brand ? brand.logo_url : '',
                                            previewId: 'logo-preview'
                                        }) %>
                                        <input type="hidden" name="existing_logo_url" value="<%= brand ? brand.logo_url : '' %>">
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Powered By</label>
                                        <input type="text" name="powered_by"
                                            value="<%= brand ? brand.powered_by : '' %>"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500">
                                    </div>
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Tagline / Footer
                                            Description</label>
                                        <textarea name="tagline" rows="2"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500"><%= brand ? brand.tagline : '' %></textarea>
                                    </div>
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-medium text-gray-700 mb-1">Copyright
                                            Text</label>
                                        <input type="text" name="copyright_text"
                                            value="<%= brand ? brand.copyright_text : '' %>"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500">
                                    </div>
                                </div>

                                <!-- Colors -->
                                <h3 class="text-sm font-bold text-gray-700 mt-6 mb-3 flex items-center gap-2">
                                    <span class="material-icons text-sm text-blue-500">palette</span> Brand Colors
                                </h3>
                                <!-- Color preview strip -->
                                <div class="flex gap-1 mb-4 rounded-xl overflow-hidden h-3 shadow-inner">
                                    <div id="preview_primary_color" class="flex-1"
                                        style="background: <%= brand ? brand.primary_color : '#0056b3' %>"></div>
                                    <div id="preview_primary_hover_color" class="flex-1"
                                        style="background: <%= brand ? brand.primary_hover_color : '#004494' %>"></div>
                                    <div id="preview_accent_color_1" class="flex-1"
                                        style="background: <%= brand ? brand.accent_color_1 : '#76bc43' %>"></div>
                                    <div id="preview_accent_color_2" class="flex-1"
                                        style="background: <%= brand ? brand.accent_color_2 : '#6658a6' %>"></div>
                                    <div id="preview_accent_color_3" class="flex-1"
                                        style="background: <%= brand ? brand.accent_color_3 : '#f58220' %>"></div>
                                </div>
                                <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Primary</label>
                                        <div class="flex items-center gap-2">
                                            <input type="color" name="primary_color"
                                                value="<%= brand ? brand.primary_color : '#0056b3' %>"
                                                class="color-picker w-10 h-10 rounded-lg border-2 border-gray-200 cursor-pointer p-0.5"
                                                data-preview="preview_primary_color">
                                            <div class="flex-1">
                                                <input type="text"
                                                    class="color-hex w-full border border-gray-300 rounded-lg px-2 py-1 text-xs font-mono text-center"
                                                    value="<%= brand ? brand.primary_color : '#0056b3' %>" readonly>
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Primary
                                            Hover</label>
                                        <div class="flex items-center gap-2">
                                            <input type="color" name="primary_hover_color"
                                                value="<%= brand ? brand.primary_hover_color : '#004494' %>"
                                                class="color-picker w-10 h-10 rounded-lg border-2 border-gray-200 cursor-pointer p-0.5"
                                                data-preview="preview_primary_hover_color">
                                            <div class="flex-1">
                                                <input type="text"
                                                    class="color-hex w-full border border-gray-300 rounded-lg px-2 py-1 text-xs font-mono text-center"
                                                    value="<%= brand ? brand.primary_hover_color : '#004494' %>"
                                                    readonly>
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Accent 1
                                            (Green)</label>
                                        <div class="flex items-center gap-2">
                                            <input type="color" name="accent_color_1"
                                                value="<%= brand ? brand.accent_color_1 : '#76bc43' %>"
                                                class="color-picker w-10 h-10 rounded-lg border-2 border-gray-200 cursor-pointer p-0.5"
                                                data-preview="preview_accent_color_1">
                                            <div class="flex-1">
                                                <input type="text"
                                                    class="color-hex w-full border border-gray-300 rounded-lg px-2 py-1 text-xs font-mono text-center"
                                                    value="<%= brand ? brand.accent_color_1 : '#76bc43' %>" readonly>
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Accent 2
                                            (Purple)</label>
                                        <div class="flex items-center gap-2">
                                            <input type="color" name="accent_color_2"
                                                value="<%= brand ? brand.accent_color_2 : '#6658a6' %>"
                                                class="color-picker w-10 h-10 rounded-lg border-2 border-gray-200 cursor-pointer p-0.5"
                                                data-preview="preview_accent_color_2">
                                            <div class="flex-1">
                                                <input type="text"
                                                    class="color-hex w-full border border-gray-300 rounded-lg px-2 py-1 text-xs font-mono text-center"
                                                    value="<%= brand ? brand.accent_color_2 : '#6658a6' %>" readonly>
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Accent 3
                                            (Orange)</label>
                                        <div class="flex items-center gap-2">
                                            <input type="color" name="accent_color_3"
                                                value="<%= brand ? brand.accent_color_3 : '#f58220' %>"
                                                class="color-picker w-10 h-10 rounded-lg border-2 border-gray-200 cursor-pointer p-0.5"
                                                data-preview="preview_accent_color_3">
                                            <div class="flex-1">
                                                <input type="text"
                                                    class="color-hex w-full border border-gray-300 rounded-lg px-2 py-1 text-xs font-mono text-center"
                                                    value="<%= brand ? brand.accent_color_3 : '#f58220' %>" readonly>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-6 flex justify-end">
                                    <button type="submit"
                                        class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2 transition-colors shadow-sm">
                                        <span class="material-icons text-sm">save</span> Save Brand
                                    </button>
                                </div>
                            </div>
                        </form>
                        <% } %>

                        <% if (brand && typeof sections !=='undefined' ) { %>

                            <% if (activeTab === 'hero') { %>
                            <!-- HERO SECTION -->
                            <% const hero=sections.hero || {}; %>
                                <form method="POST" enctype="multipart/form-data" action="/admin/brands/<%= brand.uuid %>/sections/hero">
                                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
                                        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                                            <span class="material-icons text-green-500">view_carousel</span> Hero
                                            Section
                                        </h2>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Badge
                                                    Text</label>
                                                <input type="text" name="badge" value="<%= hero.badge || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Heading Line
                                                    1</label>
                                                <input type="text" name="heading_line1"
                                                    value="<%= hero.heading_line1 || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Heading Line
                                                    2</label>
                                                <input type="text" name="heading_line2"
                                                    value="<%= hero.heading_line2 || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Heading Line
                                                    3</label>
                                                <input type="text" name="heading_line3"
                                                    value="<%= hero.heading_line3 || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div class="md:col-span-2">
                                                <label
                                                    class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                                <textarea name="description" rows="2"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"><%= hero.description || '' %></textarea>
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">CTA Primary
                                                    Text</label>
                                                <input type="text" name="cta_primary_text"
                                                    value="<%= hero.cta_primary_text || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">CTA Primary
                                                    Link</label>
                                                <input type="text" name="cta_primary_href"
                                                    value="<%= hero.cta_primary_href || '#catalog' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">CTA
                                                    Secondary
                                                    Text</label>
                                                <input type="text" name="cta_secondary_text"
                                                    value="<%= hero.cta_secondary_text || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">CTA
                                                    Secondary
                                                    Link</label>
                                                <input type="text" name="cta_secondary_href"
                                                    value="<%= hero.cta_secondary_href || '#' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                            </div>
                                            <div class="md:col-span-2">
                                                <%- include('../components/imageUpload', { 
                                                    name: 'hero_image', 
                                                    existingUrl: hero.hero_image_url || '',
                                                    previewId: 'hero-image'
                                                }) %>
                                                <input type="hidden" name="existing_hero_image_url" value="<%= hero.hero_image_url || '' %>">
                                            </div>
                                        </div>
                                        <div class="mt-4 flex justify-end">
                                            <button type="submit"
                                                class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 transition-colors">
                                                <span class="material-icons text-sm">save</span> Save Hero
                                            </button>
                                        </div>
                                    </div>
                                </form>
                                <% } %>

                                <% if (activeTab === 'features') { %>
                                <!-- FEATURES HEADER SECTION -->
                                <% const fh=sections.features_header || {}; %>
                                    <form method="POST" action="/admin/brands/<%= brand.uuid %>/sections/features_header">
                                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
                                            <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                                                <span class="material-icons text-purple-500">auto_awesome</span>
                                                Features
                                                Section Header
                                            </h2>
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                <div>
                                                    <label
                                                        class="block text-sm font-medium text-gray-700 mb-1">Badge</label>
                                                    <input type="text" name="badge" value="<%= fh.badge || '' %>"
                                                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                </div>
                                                <div>
                                                    <label
                                                        class="block text-sm font-medium text-gray-700 mb-1">Heading</label>
                                                    <input type="text" name="heading" value="<%= fh.heading || '' %>"
                                                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                </div>
                                                <div>
                                                    <label class="block text-sm font-medium text-gray-700 mb-1">Heading
                                                        Highlight</label>
                                                    <input type="text" name="heading_highlight"
                                                        value="<%= fh.heading_highlight || '' %>"
                                                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                </div>
                                                <div>
                                                    <label
                                                        class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                                                    <input type="text" name="description"
                                                        value="<%= fh.description || '' %>"
                                                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                </div>
                                            </div>
                                            <div class="mt-4 flex justify-end">
                                                <button type="submit"
                                                    class="bg-purple-600 hover:bg-purple-700 text-white px-5 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 transition-colors">
                                                    <span class="material-icons text-sm">save</span> Save
                                                </button>
                                            </div>
                                        </div>
                                    </form>

                                    <!-- FEATURES LIST -->
                                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
                                        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                                            <span class="material-icons text-purple-500">star</span> Feature Cards
                                        </h2>
                                        <% if (features && features.length> 0) { %>
                                            <div class="space-y-3 mb-4">
                                                <% features.forEach(f=> { %>
                                                    <form method="POST"
                                                        action="/admin/brands/<%= brand.uuid %>/features/<%= f.uuid %>/update"
                                                        class="bg-gray-50 rounded-xl p-4">
                                                        <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
                                                            <div>
                                                                <label class="block text-xs font-medium text-gray-600 mb-1">Icon</label>
                                                                <%- include('../components/iconSelect', { 
                                                                    name: 'icon-select-' + f.uuid, 
                                                                    value: f.icon,
                                                                    linkedInput: 'icon',
                                                                    defaultIcons: true
                                                                }) %>
                                                            </div>
                                                            <div>
                                                                <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
                                                                <input type="text" name="title" value="<%= f.title %>"
                                                                    class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-sm">
                                                            </div>
                                                            <div>
                                                                <label
                                                                    class="block text-xs font-medium text-gray-600 mb-1">Color</label>
                                                                <select name="color_class"
                                                                    class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-sm">
                                                                    <option value="primary" <%=f.color_class==='primary'
                                                                        ? 'selected' : '' %>>Primary</option>
                                                                    <option value="accent-purple"
                                                                        <%=f.color_class==='accent-purple' ? 'selected'
