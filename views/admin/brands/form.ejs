                        <div id="brand-preview-scale-container" class="relative transition-all duration-300 mx-auto" style="transform-origin: top left;">
                            <iframe id="brand-preview-iframe" src="/<%= brand.slug %>" class="bg-white transition-all duration-300 overflow-y-auto block w-full" title="Live Preview"></iframe>
                        </div>
                    </div>
                </div> <!-- END KOLOM 2 -->
                <% } %>

                </div> <!-- END LAYOUT 2 KOLOM -->

        </main>
    </div> <!-- END main-content -->

        <script>
            // Sync color picker with hex text and preview strip
            document.querySelectorAll('.color-picker').forEach(picker => {
                picker.addEventListener('input', function () {
                    // Update hex display
                    const hexInput = this.closest('div').querySelector('.color-hex');
                    if (hexInput) hexInput.value = this.value;
                    // Update preview strip
                    const previewId = this.dataset.preview;
                    if (previewId) {
                        const previewEl = document.getElementById(previewId);
                        if (previewEl) previewEl.style.background = this.value;
                    }
                });
            });

            // Logo URL preview
            function updateLogoPreview(url) {
                const container = document.getElementById('logo_preview');
                if (!container) return;
                if (url && url.trim()) {
                    container.innerHTML = '<img src="' + url + '" alt="Logo Preview" class="w-full h-full object-contain" onerror="this.parentElement.innerHTML=\'<span class=\\\'material-icons text-red-300 text-2xl\\\'>broken_image</span>\'" />';
                } else {
                    container.innerHTML = '<span class="material-icons text-gray-300 text-2xl">image</span>';
                }
            }

            // Template selection for edit form
            let selectedTemplatePathEdit = null;
            
            function selectTemplateEdit(id, filePath) {
                selectedTemplatePathEdit = filePath;
                document.getElementById('selected-template-id-edit').value = id;
                
                // Update UI
                document.querySelectorAll('.template-card').forEach(card => {
                    card.classList.remove('border-blue-500', 'ring-2', 'ring-blue-200');
                    const check = card.querySelector('.selected-check');
                    if (check) check.classList.replace('bg-blue-500', 'bg-gray-400');
                });
                
                const selectedCard = document.getElementById('template-card-edit-' + id);
                if (selectedCard) {
                    selectedCard.classList.add('border-blue-500', 'ring-2', 'ring-blue-200');
                    const check = selectedCard.querySelector('.selected-check');
                    if (check) check.classList.replace('bg-gray-400', 'bg-blue-500');
                }
                
                // Update preview - reload brand preview iframe to reflect template change
                if (filePath) {
                    const brandIframe = document.getElementById('brand-preview-iframe');
                    if (brandIframe) brandIframe.contentWindow.location.reload();
                }
            }

            // Initialize template selection on page load
            document.addEventListener('DOMContentLoaded', function() {
                const initialTemplateId = document.getElementById('selected-template-id-edit').value;
                if (initialTemplateId) {
                    const templates = <%- JSON.stringify(templates) %>;
                    const template = templates.find(t => t.id == initialTemplateId);
                    if (template) {
                        // Only update UI state, don't reload preview
                        selectedTemplatePathEdit = template.file_path;
                        const selectedCard = document.getElementById('template-card-edit-' + template.id);
                        if (selectedCard) {
                            selectedCard.classList.add('border-blue-500', 'ring-2', 'ring-blue-200');
                            const check = selectedCard.querySelector('.selected-check');
                            if (check) check.classList.replace('bg-gray-400', 'bg-blue-500');
                        }
                    }
                }
            });
        </script>

        <% if (brand) { %>
        <!-- Script for Live Preview Modes (Brand) -->
        <script>
            let brandCurrentMode = 'desktop';

            function applyBrandScale() {
                const wrapper = document.getElementById('brand-preview-wrapper');
                const scaleContainer = document.getElementById('brand-preview-scale-container');
                const iframe = document.getElementById('brand-preview-iframe');
                if (!wrapper || !scaleContainer || !iframe) return;

                // Toggle padding on wrapper based on mode
                if (brandCurrentMode === 'desktop') {
                    wrapper.classList.remove('p-4', 'sm:p-6', 'md:p-8');
                    wrapper.classList.add('p-0');
                } else {
                    wrapper.classList.remove('p-0');
                    wrapper.classList.add('p-4', 'md:p-8');
                }

                // Get available dimensions, accounting for padding
                const padding = brandCurrentMode === 'desktop' ? 0 : (window.innerWidth >= 768 ? 64 : 32);
                const availableWidth = wrapper.clientWidth - padding;
                const availableHeight = wrapper.clientHeight - padding;

                let targetWidth, targetHeight;
                let scale;

                if (brandCurrentMode === 'mobile') {
                    targetWidth = 375;
                    targetHeight = 812;

                    scale = Math.min(availableHeight / targetHeight, availableWidth / targetWidth);
                    if (scale > 1) scale = 1;

                    scaleContainer.style.transformOrigin = 'top left';

                    iframe.className = "bg-white shadow-[0_0_0_12px_#1e293b,0_20px_25px_-5px_rgb(0,0,0,0.1),0_8px_10px_-6px_rgb(0,0,0,0.1)] overflow-y-auto block w-full rounded-[2.5rem] transition-all duration-300";

                } else if (brandCurrentMode === 'tablet') {
                    targetWidth = 768;
                    targetHeight = 1024;

                    scale = Math.min(availableHeight / targetHeight, availableWidth / targetWidth);
                    if (scale > 1) scale = 1;

                    scaleContainer.style.transformOrigin = 'top left';

                    iframe.className = "bg-white shadow-[0_0_0_12px_#1e293b,0_20px_25px_-5px_rgb(0,0,0,0.1),0_8px_10px_-6px_rgb(0,0,0,0.1)] overflow-y-auto block w-full rounded-[1.5rem] transition-all duration-300";

                } else { // desktop
                    targetWidth = 1280;

                    scale = availableWidth / targetWidth;
                    if (scale > 1) scale = 1;

                    targetHeight = availableHeight / scale;

                    scaleContainer.style.transformOrigin = 'top left';

                    iframe.className = "bg-white overflow-y-auto block w-full transition-all duration-300 border-none rounded-none";
                }

                // Apply dimensions to iframe
                iframe.style.width = targetWidth + 'px';
                iframe.style.height = targetHeight + 'px';

                // Apply scale to the container
                scaleContainer.style.transform = `scale(${scale})`;
                scaleContainer.style.width = `${targetWidth * scale}px`;
                scaleContainer.style.height = `${targetHeight * scale}px`;
            }

            function setBrandPreviewMode(mode) {
                brandCurrentMode = mode;
                const container = document.getElementById('brand-preview-container');
                const buttons = document.querySelectorAll('.brand-preview-mode-btn');

                // Reset state
                buttons.forEach(btn => {
                    btn.classList.remove('active-mode', 'text-blue-600', 'bg-white', 'shadow-sm', 'border-slate-200');
                    btn.classList.add('text-slate-500', 'border-transparent');
                });

                // Set active button
                const activeBtn = document.getElementById(`btn-brand-mode-${mode}`);
                if (activeBtn) {
                    activeBtn.classList.remove('text-slate-500', 'border-transparent');
                    activeBtn.classList.add('active-mode', 'text-blue-600', 'bg-white', 'shadow-sm', 'border-slate-200');
                }

                // Adjust container width
                if (mode === 'mobile') {
                    container.style.width = '400px';
                    container.style.maxWidth = '100%';
                } else {
                    container.style.width = '';
                    container.style.maxWidth = '';
                }

                // Small delay to allow CSS width transition before scaling
                setTimeout(applyBrandScale, 310);
            }

            // Initialize on load and on window resize
            window.addEventListener('load', () => {
                setBrandPreviewMode('desktop');
                applyBrandScale();
            });
            window.addEventListener('resize', applyBrandScale);
        </script>
        <% } %>

    <style>
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .sidebar-transition { transition: width 300ms ease-in-out; }
        .card-hover { transition: transform 200ms ease, box-shadow 200ms ease; }
        .card-hover:hover { transform: translateY(-2px); box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1); }
        .page-enter { animation: fadeIn 300ms ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>

    <%- include('../partials/_scripts') %>
</body>
