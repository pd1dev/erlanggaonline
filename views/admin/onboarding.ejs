<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to CMS Admin</title>
    <link rel="icon" type="image/jpeg" href="/favicon.jpg">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        primary: { 50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd', 400: '#60a5fa', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8', 800: '#1e40af', 900: '#1e3a8a' }
                    }
                }
            }
        }
    </script>
    <style>
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .animate-float { animation: float 3s ease-in-out infinite; }
        .animate-fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
        .animate-pulse-slow { animation: pulse 2s ease-in-out infinite; }
        
        .step-card {
            transition: all 300ms ease;
        }
        .step-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15);
        }
        .step-card.active {
            border-color: #3b82f6;
            background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
        }
    </style>
</head>

<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 min-h-screen font-sans">
    <div class="min-h-screen flex flex-col">
        <!-- Header -->
        <header class="py-6 px-8">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30">
                    <span class="material-icons text-white text-2xl">dashboard</span>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">CMS Admin</h1>
                    <p class="text-slate-400 text-sm">Welcome to your content management system</p>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="flex-1 px-8 pb-8">
            <div class="max-w-4xl mx-auto">
                <!-- Welcome Message -->
                <div class="text-center mb-12 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <h2 class="text-3xl font-bold text-white mb-4">Welcome, <%= user ? user.username : 'Admin' %>! 👋</h2>
                    <p class="text-slate-400 text-lg max-w-2xl mx-auto">Selamat datang di CMS Admin. Mari kami bantu Anda memulai dengan panduan cepat ini.</p>
                </div>

                <!-- Steps -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                    <!-- Step 1 -->
                    <div class="step-card bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 animate-fade-in-up" style="animation-delay: 0.2s;" id="step-1">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-blue-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="material-icons text-blue-400">storefront</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-white mb-2">1. Buat Brand Pertama</h3>
                                <p class="text-slate-400 text-sm mb-4">Buat brand pertama Anda untuk mulai membangun Presence online.</p>
                                <a href="/admin/brands/create" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">
                                    <span class="material-icons text-sm">add</span> Buat Brand
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="step-card bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 animate-fade-in-up" style="animation-delay: 0.3s;" id="step-2">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-emerald-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="material-icons text-emerald-400">palette</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-white mb-2">2. Kustomisasi Tampilan</h3>
                                <p class="text-slate-400 text-sm mb-4">Pilih warna, logo, dan tema yang sesuai dengan brand Anda.</p>
                                <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-700 text-slate-400 rounded-lg text-sm font-medium cursor-not-allowed">
                                    <span class="material-icons text-sm">edit</span> Setelah buat brand
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="step-card bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 animate-fade-in-up" style="animation-delay: 0.4s;" id="step-3">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-violet-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="material-icons text-violet-400">inventory_2</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-white mb-2">3. Tambahkan Produk</h3>
                                <p class="text-slate-400 text-sm mb-4">Masukkan produk atau layanan yang ingin Anda tayangkan.</p>
                                <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-700 text-slate-400 rounded-lg text-sm font-medium cursor-not-allowed">
                                    <span class="material-icons text-sm">add</span> Setelah buat brand
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Step 4 -->
                    <div class="step-card bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 animate-fade-in-up" style="animation-delay: 0.5s;" id="step-4">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-orange-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
                                <span class="material-icons text-orange-400">public</span>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-white mb-2">4. Publikasikan</h3>
                                <p class="text-slate-400 text-sm mb-4">Brand Anda siap untuk dilihat oleh dunia!</p>
                                <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-700 text-slate-400 rounded-lg text-sm font-medium cursor-not-allowed">
                                    <span class="material-icons text-sm">visibility</span> Setelah setup selesai
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Checklist -->
                <div class="bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 mb-8 animate-fade-in-up" style="animation-delay: 0.6s;">
                    <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                        <span class="material-icons text-blue-400">checklist</span>
                        Checklist Completion
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="checklist">
                        <label class="flex items-center gap-3 p-3 bg-slate-700/50 rounded-xl cursor-pointer hover:bg-slate-700 transition-colors">
                            <input type="checkbox" class="w-5 h-5 rounded border-slate-600 text-blue-600 focus:ring-blue-500 focus:ring-offset-slate-800" onchange="updateProgress()">
                            <span class="text-slate-300 text-sm">Buat brand pertama</span>
                        </label>
                        <label class="flex items-center gap-3 p-3 bg-slate-700/50 rounded-xl cursor-pointer hover:bg-slate-700 transition-colors">
                            <input type="checkbox" class="w-5 h-5 rounded border-slate-600 text-blue-600 focus:ring-blue-500 focus:ring-offset-slate-800" onchange="updateProgress()">
                            <span class="text-slate-300 text-sm">Upload logo brand</span>
                        </label>
                        <label class="flex items-center gap-3 p-3 bg-slate-700/50 rounded-xl cursor-pointer hover:bg-slate-700 transition-colors">
                            <input type="checkbox" class="w-5 h-5 rounded border-slate-600 text-blue-600 focus:ring-blue-500 focus:ring-offset-slate-800" onchange="updateProgress()">
                            <span class="text-slate-300 text-sm">Pilih warna tema</span>
                        </label>
                        <label class="flex items-center gap-3 p-3 bg-slate-700/50 rounded-xl cursor-pointer hover:bg-slate-700 transition-colors">
                            <input type="checkbox" class="w-5 h-5 rounded border-slate-600 text-blue-600 focus:ring-blue-500 focus:ring-offset-slate-800" onchange="updateProgress()">
                            <span class="text-slate-300 text-sm">Tambah produk pertama</span>
                        </label>
                    </div>
                    
                    <!-- Progress Bar -->
                    <div class="mt-6">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm text-slate-400">Progress</span>
                            <span class="text-sm font-medium text-white" id="progress-text">0%</span>
                        </div>
                        <div class="h-2 bg-slate-700 rounded-full overflow-hidden">
                            <div id="progress-bar" class="h-full bg-gradient-to-r from-blue-500 to-blue-400 rounded-full transition-all duration-500" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up" style="animation-delay: 0.7s;">
                    <a href="/admin" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/25">
                        <span class="material-icons">dashboard</span>
                        ke Dashboard
                    </a>
                    <a href="/admin/brands/create" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-slate-700 text-white rounded-xl font-medium hover:bg-slate-600 transition-colors border border-slate-600">
                        <span class="material-icons">add</span>
                        Buat Brand Sekarang
                    </a>
                </div>

                <!-- Skip Button -->
                <div class="text-center mt-6">
                    <button onclick="skipOnboarding()" class="text-slate-500 hover:text-slate-300 text-sm transition-colors">
                        Lewati tutorial ini
                    </button>
                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="py-6 px-8 border-t border-slate-800">
            <div class="text-center text-slate-500 text-sm">
                <p>CMS Admin &copy; 2026. All rights reserved.</p>
            </div>
        </footer>
    </div>

    <script>
        function updateProgress() {
            const checkboxes = document.querySelectorAll('#checklist input[type="checkbox"]');
            const checked = document.querySelectorAll('#checklist input[type="checkbox"]:checked');
            const progress = (checked.length / checkboxes.length) * 100;
            
            document.getElementById('progress-bar').style.width = progress + '%';
            document.getElementById('progress-text').textContent = Math.round(progress) + '%';
            
            // Save to localStorage
            localStorage.setItem('onboarding_progress', progress);
            localStorage.setItem('onboarding_checked', JSON.stringify(Array.from(checked).map(c => c.nextElementSibling.textContent.trim())));
        }

        function skipOnboarding() {
            localStorage.setItem('onboarding_skipped', 'true');
            window.location.href = '/admin';
        }

        // Load saved progress
        window.addEventListener('DOMContentLoaded', () => {
            const savedProgress = localStorage.getItem('onboarding_progress');
            const savedChecked = JSON.parse(localStorage.getItem('onboarding_checked') || '[]');
            
            if (savedProgress && savedProgress > 0) {
                const checkboxes = document.querySelectorAll('#checklist input[type="checkbox"]');
                document.getElementById('progress-bar').style.width = savedProgress + '%';
                document.getElementById('progress-text').textContent = Math.round(savedProgress) + '%';
            }
            
            // Check if already completed
            if (savedProgress == 100) {
                setTimeout(() => {
                    window.location.href = '/admin';
                }, 1000);
            }
        });
    </script>
</body>
</html>
