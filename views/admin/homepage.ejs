<%- include('partials/_head', { title: 'Homepage Settings - CMS Admin' }) %>
<body class="bg-slate-100 font-sans antialiased">
<%- include('partials/_sidebar', { user, activePage: 'homepage' }) %>

    <!-- Main Content -->
    <div id="main-content" class="sidebar-transition ml-0 lg:ml-64">
        <%- include('partials/_header', { title: 'Homepage Settings', user }) %>

        <main class="p-3 md:p-6 page-enter">

            <% if (success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-3 md:px-4 py-2 md:py-3 rounded-lg md:rounded-xl mb-4 md:mb-6 flex items-center gap-2 text-xs md:text-sm">
                    <span class="material-icons text-sm">check_circle</span>
                    <%= success %>
                </div>
            <% } %>

            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-3 md:px-4 py-2 md:py-3 rounded-lg md:rounded-xl mb-4 md:mb-6 flex items-center gap-2 text-xs md:text-sm">
                    <span class="material-icons text-sm">error</span>
                    <%= error %>
                </div>
            <% } %>

            <h1 class="text-xl md:text-2xl font-bold text-slate-900 mb-4 md:mb-6">Homepage Settings</h1>

            <!-- LAYOUT 2 KOLOM (GRID) -->
            <div class="flex flex-col lg:flex-row gap-6 items-start">
                
                <!-- KOLOM 1: Form Setting -->
                <div class="w-full flex-1 min-w-0 flex flex-col">
                            <!-- Tabs -->
                            <div class="mb-4 md:mb-8 w-full overflow-hidden">
                                <div class="flex flex-wrap gap-1 bg-gray-100 p-1 rounded-xl w-full">
                                    <% ['general', 'hero' , 'banners' , 'products' , 'testimonials' , 'navigation', 'footer' ].forEach(tab=> { %>
                                        <a href="/admin/homepage?tab=<%= tab %>"
                                            class="px-2.5 md:px-3 py-1.5 md:py-2 rounded-lg text-xs md:text-sm font-medium transition-all whitespace-nowrap flex items-center gap-1 flex-1 sm:flex-none justify-center <%= activeTab === tab ? 'bg-white text-blue-600 shadow-sm ring-1 ring-gray-200' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50' %>">
                                            <span class="material-icons text-xs md:text-sm"><%= tab==='general' ? 'settings' : tab==='hero' ? 'view_carousel' : tab==='banners' ? 'perm_media' : tab==='products' ? 'inventory_2' : tab==='testimonials' ? 'rate_review' : tab==='navigation' ? 'menu' : 'copyright' %></span>
                                            <span class="hidden sm:inline"><%= tab==='general' ? 'Umum' : tab==='hero' ? 'Hero & Promo' : tab==='banners' ? 'Banner' : tab==='products' ? 'Produk' : tab==='testimonials' ? 'Testimoni' : tab==='navigation' ? 'Navigasi' : 'Footer' %></span>
                                        </a>
                                    <% }); %>
                                </div>
                            </div>

                                    <!-- ==================== GENERAL TAB ==================== -->
                            <% if (activeTab==='general' ) { %>
                                <form method="POST" action="/admin/homepage/settings" enctype="multipart/form-data">
                                    <input type="hidden" name="_tab" value="general">
                                    <div class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6 space-y-4 md:space-y-5">
                                        <h2 class="text-base md:text-lg font-bold flex items-center gap-2"><span
                                                class="material-icons text-blue-500 text-sm md:text-lg">settings</span> Pengaturan Umum
                                        </h2>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                            <div>
                                                <label class="block text-sm font-medium text-gray-700 mb-1">Nama
                                                    Situs</label>
                                                <input type="text" name="site_name"
                                                    value="<%= settings.site_name || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                                            </div>
                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
                                                <input type="text" name="site_tagline"
                                                    value="<%= settings.site_tagline || '' %>"
                                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                                            </div>
                                        </div>
                                        <div>
                                            <%- include('components/imageUpload', { 
                                                name: 'logo', 
                                                existingUrl: settings.logo_url || '',
                                                previewId: 'logo-preview'
                                            }) %>
                                            <input type="hidden" name="existing_logo_url" value="<%= settings.logo_url || '' %>">
                                            <p class="text-xs text-gray-400 mt-1">URL gambar logo yang akan ditampilkan
                                                di
                                                navbar homepage</p>
                                        </div>
                                        <div>
                                            <label class="block text-sm font-medium text-gray-700 mb-1">Primary
                                                Color</label>
                                            <div class="flex items-center gap-3">
                                                <input type="color" name="primary_color"
                                                    value="<%= settings.primary_color || '#257bf4' %>"
                                                    class="w-10 h-9 md:w-12 md:h-10 rounded cursor-pointer border-0">
                                                <span class="text-sm text-gray-500">
                                                    <%= settings.primary_color || '#257bf4' %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="pt-3 md:pt-4 flex justify-end">
                                            <button type="submit"
                                                class="bg-blue-600 hover:bg-blue-700 text-white px-4 md:px-6 py-2 md:py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2 transition-colors w-full sm:w-auto justify-center">
                                                <span class="material-icons text-sm">save</span> Simpan
                                            </button>
                                        </div>
                                    </div>
                                </form>
                                <% } %>

                                    <!-- ==================== HERO TAB ==================== -->
                                    <% if (activeTab==='hero' ) { %>
                                        <form method="POST" action="/admin/homepage/settings" enctype="multipart/form-data">
                                            <input type="hidden" name="_tab" value="hero">
                                            <div class="space-y-4 md:space-y-6">
                                                <!-- Hero Content -->
                                                <div
                                                    class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6 space-y-3 md:space-y-4">
                                                    <h2 class="text-base md:text-lg font-bold flex items-center gap-2"><span
                                                            class="material-icons text-blue-500 text-sm md:text-lg">view_carousel</span>
                                                        Hero
                                                        Section</h2>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Badge
                                                                Text</label>
                                                            <input type="text" name="hero_badge"
                                                                value="<%= settings.hero_badge || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                        </div>
                                                        <div>
                                                            <label class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Badge Icon</label>
                                                            <%- include('./components/iconSelect', { 
                                                                name: 'hero_badge_icon', 
                                                                value: settings.hero_badge_icon || '',
                                                                defaultIcons: true
                                                            }) %>
                                                        </div>
                                                    </div>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Judul</label>
                                                            <input type="text" name="hero_title"
                                                                value="<%= settings.hero_title || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Judul
                                                                Highlight</label>
                                                            <input type="text" name="hero_title_highlight"
                                                                value="<%= settings.hero_title_highlight || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <label
                                                            class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Deskripsi</label>
                                                        <textarea name="hero_description" rows="2 md:3"
                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none"><%= settings.hero_description || '' %></textarea>
                                                    </div>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">CTA
                                                                1 Text</label>
                                                            <input type="text" name="hero_cta1_text"
                                                                value="<%= settings.hero_cta1_text || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">CTA
                                                                1 Link</label>
                                                            <input type="text" name="hero_cta1_href"
                                                                value="<%= settings.hero_cta1_href || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">CTA
                                                                2 Text</label>
                                                            <input type="text" name="hero_cta2_text"
                                                                value="<%= settings.hero_cta2_text || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">CTA
                                                                2 Link</label>
                                                            <input type="text" name="hero_cta2_href"
                                                                value="<%= settings.hero_cta2_href || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Products Heading -->
                                                <div
                                                    class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6 space-y-3 md:space-y-4">
                                                    <h2 class="text-base md:text-lg font-bold flex items-center gap-2"><span
                                                            class="material-icons text-indigo-500 text-sm md:text-lg">inventory_2</span>
                                                        Section Produk</h2>
                                                    <div>
                                                        <label
                                                            class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Heading
                                                            Produk</label>
                                                        <input type="text" name="products_heading"
                                                            value="<%= settings.products_heading || '' %>"
                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                    </div>
                                                </div>

                                                <!-- Survey CTA -->
                                                <div
                                                    class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6 space-y-3 md:space-y-4">
                                                    <h2 class="text-base md:text-lg font-bold flex items-center gap-2"><span
                                                            class="material-icons text-green-500 text-sm md:text-lg">poll</span> Survey CTA
                                                    </h2>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Heading</label>
                                                            <input type="text" name="survey_heading"
                                                                value="<%= settings.survey_heading || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Button
                                                                Text</label>
                                                            <input type="text" name="survey_button_text"
                                                                value="<%= settings.survey_button_text || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <label
                                                            class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Deskripsi</label>
                                                        <textarea name="survey_description" rows="2"
                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"><%= settings.survey_description || '' %></textarea>
                                                    </div>
                                                    <div>
                                                        <label
                                                            class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Button
                                                            Link</label>
                                                        <input type="text" name="survey_button_href"
                                                            value="<%= settings.survey_button_href || '' %>"
                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                    </div>
                                                </div>

                                                <!-- Testimonials Header -->
                                                <div
                                                    class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6 space-y-3 md:space-y-4">
                                                    <h2 class="text-base md:text-lg font-bold flex items-center gap-2"><span
                                                            class="material-icons text-purple-500 text-sm md:text-lg">format_quote</span>
                                                        Section Testimoni</h2>
                                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Badge</label>
                                                            <input type="text" name="testimonials_badge"
                                                                value="<%= settings.testimonials_badge || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                        <div>
                                                            <label
                                                                class="block text-xs md:text-sm font-medium text-gray-700 mb-1">Heading</label>
                                                            <input type="text" name="testimonials_heading"
                                                                value="<%= settings.testimonials_heading || '' %>"
                                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="flex justify-end">
                                                    <button type="submit"
                                                        class="bg-blue-600 hover:bg-blue-700 text-white px-4 md:px-6 py-2 md:py-2.5 rounded-lg text-sm font-semibold flex items-center gap-2 w-full sm:w-auto justify-center">
                                                        <span class="material-icons text-sm">save</span> Simpan Semua
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                        <% } %>

                                            <!-- ==================== BANNERS TAB ==================== -->
                                            <% if (activeTab==='banners' ) { %>
                                                <div class="space-y-4 md:space-y-6">
                                                    <!-- Preview Banner Slider -->
                                                    <% if (banners.length > 0) { %>
                                                        <div class="bg-white rounded-xl md:rounded-2xl shadow-sm border border-gray-100 p-4 md:p-6">
                                                            <h2 class="text-base md:text-lg font-bold mb-3 md:mb-4 flex items-center gap-2">
                                                                <span class="material-icons text-purple-500 text-sm md:text-lg">visibility</span>
                                                                Preview Banner Slider
                                                            </h2>
                                                            <p class="text-xs md:text-sm text-gray-500 mb-3 md:mb-4">Preview tampilan banner di homepage</p>
                                                            
                                                            <div class="relative h-40 md:h-64 w-full rounded-lg md:rounded-xl overflow-hidden" id="admin-banner-carousel">
                                                                <% banners.forEach((banner, idx)=> { %>
                                                                    <div class="banner-slide absolute inset-0 transition-opacity duration-700 ease-in-out <%= idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0' %>"
                                                                        style="background: linear-gradient(135deg, <%= banner.bg_gradient_from || '#257bf4' %>, <%= banner.bg_gradient_to || '#60a5fa' %>);">
                                                                        <% if (banner.image_url) { %>
                                                                            <img alt="<%= banner.title %>"
                                                                                class="absolute inset-0 h-full w-full object-cover"
                                                                                src="<%= banner.image_url %>" />
                                                                        <% } %>
                                                                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                                                                        <% if (banner.badge) { %>
                                                                            <div class="absolute top-3 left-3 rounded-full bg-white/20 px-3 py-0.5 text-xs font-bold uppercase backdrop-blur-md border border-white/30 shadow-sm z-10 text-white">
                                                                                <%= banner.badge %>
                                                                            </div>
                                                                        <% } %>
                                                                        <div class="absolute inset-0 flex flex-col items-center justify-center z-10 text-center px-4">
                                                                            <h3 class="text-xl md:text-2xl font-black text-white drop-shadow-lg mb-2">
                                                                                <%= banner.title %>
                                                                            </h3>
                                                                            <% if (banner.description || banner.promo_code) { %>
                                                                                <p class="text-sm text-white opacity-90 mb-3">
                                                                                    <%= banner.description %>
                                                                                    <% if (banner.promo_code) { %>
                                                                                        <span class="font-mono font-bold"> <%= banner.promo_code %></span>
                                                                                    <% } %>
                                                                                </p>
                                                                            <% } %>
                                                                            <% if (banner.button_text) { %>
                                                                                <span class="rounded-full bg-white px-4 py-1.5 font-bold text-sm text-gray-800 shadow-lg">
                                                                                    <%= banner.button_text %>
                                                                                </span>
                                                                            <% } %>
                                                                        </div>
                                                                    </div>
                                                                <% }); %>
                                                                
                                                                <% if (banners.length > 1) { %>
                                                                    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 z-20 flex gap-1.5">
                                                                        <% banners.forEach((_, idx)=> { %>
                                                                            <button onclick="showAdminBanner(<%= idx %>)"
                                                                                class="admin-banner-dot w-2 h-2 rounded-full transition-all <%= idx === 0 ? 'bg-white scale-125' : 'bg-white/50 hover:bg-white/75' %>"></button>
                                                                        <% }); %>
                                                                    </div>
                                                                <% } %>
                                                            </div>
                                                            
                                                            <script>
                                                                (function() {
                                                                    let current = 0;
                                                                    const slides = document.querySelectorAll('#admin-banner-carousel .banner-slide');
                                                                    const dots = document.querySelectorAll('#admin-banner-carousel .admin-banner-dot');
                                                                    const total = slides.length;
                                                                    if (total <= 1) return;
                                                                    
                                                                    function show(idx) {
                                                                        slides.forEach((s, i) => { 
                                                                            s.style.opacity = i === idx ? '1' : '0'; 
                                                                            s.style.zIndex = i === idx ? '10' : '0'; 
                                                                        });
                                                                        dots.forEach((d, i) => { 
                                                                            d.className = 'admin-banner-dot w-2 h-2 rounded-full transition-all ' + (i === idx ? 'bg-white scale-125' : 'bg-white/50 hover:bg-white/75'); 
                                                                        });
                                                                        current = idx;
                                                                    }
                                                                    
                                                                    window.showAdminBanner = function(idx) { show(idx); resetTimer(); };
                                                                    
                                                                    let timer = setInterval(() => show((current + 1) % total), 4000);
                                                                    function resetTimer() { clearInterval(timer); timer = setInterval(() => show((current + 1) % total), 4000); }
                                                                })();
                                                            </script>
                                                        </div>
                                                    <% } %>
                                                    
                                                    <div
                                                        class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                                                        <h2 class="text-lg font-bold mb-4 flex items-center gap-2"><span
                                                                class="material-icons text-blue-500">view_carousel</span>
                                                            Banner Slider (<%= banners.length %>)</h2>
                                                        <p class="text-sm text-gray-500 mb-4">Kelola banner/slide yang
                                                            tampil di bagian hero homepage. Banner aktif akan
                                                            ditampilkan
                                                            sebagai slider otomatis.</p>
                                                        <% banners.forEach(b=> { %>
                                                            <form method="POST"
                                                                action="/admin/homepage/banners/<%= b.uuid %>/update"
                                                                enctype="multipart/form-data"
                                                                class="border border-gray-100 rounded-xl p-4 mb-4 <%= b.is_active ? '' : 'opacity-60' %>">
                                                                <div class="flex items-center justify-between mb-3">
                                                                    <span
                                                                        class="text-xs font-bold px-2 py-1 rounded-full <%= b.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                                                                        <%= b.is_active ? 'Aktif' : 'Nonaktif' %>
                                                                    </span>
                                                                    <span class="text-xs text-gray-400">ID: <%= b.uuid %>
                                                                    </span>
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                                                                    <div class="md:col-span-2">
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Judul</label>
                                                                        <input type="text" name="title"
                                                                            value="<%= b.title %>"
                                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                    </div>
                                                                    <div>
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Badge</label>
                                                                        <input type="text" name="badge"
                                                                            value="<%= b.badge %>"
                                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                    </div>
                                                                </div>
                                                                <div class="mb-3">
                                                                    <label
                                                                        class="block text-xs font-medium text-gray-500 mb-1">Deskripsi</label>
                                                                    <input type="text" name="description"
                                                                        value="<%= b.description %>"
                                                                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                                                                    <div>
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Kode
                                                                            Promo</label>
                                                                        <input type="text" name="promo_code"
                                                                            value="<%= b.promo_code %>"
                                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                    </div>
                                                                    <div>
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Teks
                                                                            Tombol</label>
                                                                        <input type="text" name="button_text"
                                                                            value="<%= b.button_text %>"
                                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                    </div>
                                                                    <div>
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Link
                                                                            Tombol</label>
                                                                        <input type="text" name="button_href"
                                                                            value="<%= b.button_href %>"
                                                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                                                    </div>
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
                                                                    <div class="md:col-span-3">
                                                                        <%- include('components/imageUpload', { 
                                                                            name: 'banner_image', 
                                                                            existingUrl: b.image_url || '',
                                                                            previewId: 'banner-image-' + b.uuid
                                                                        }) %>
                                                                        <input type="hidden" name="existing_banner_image_url" value="<%= b.image_url || '' %>">
                                                                    </div>
                                                                </div>
                                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                                                                    <div>
                                                                        <label
                                                                            class="block text-xs font-medium text-gray-500 mb-1">Gradient
                                                                            From</label>
                                                                        <div class="flex items-center gap-2">
