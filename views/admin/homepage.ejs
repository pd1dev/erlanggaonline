    <!-- Script for Live Preview Modes -->
    <script>
        let currentMode = 'desktop';

        function applyScale() {
            const wrapper = document.getElementById('preview-wrapper');
            const scaleContainer = document.getElementById('preview-scale-container');
            const iframe = document.getElementById('preview-iframe');
            
            // Toggle padding on wrapper based on mode
            if (currentMode === 'desktop') {
                wrapper.classList.remove('p-4', 'sm:p-6', 'md:p-8');
                wrapper.classList.add('p-0');
            } else {
                wrapper.classList.remove('p-0');
                wrapper.classList.add('p-4', 'md:p-8');
            }

            // Get available dimensions, accounting for padding (if any)
            const padding = currentMode === 'desktop' ? 0 : (window.innerWidth >= 768 ? 64 : 32);
            const availableWidth = wrapper.clientWidth - padding;
            const availableHeight = wrapper.clientHeight - padding;
            
            let targetWidth, targetHeight;
            let scale;
            
            // Define actual virtual device sizes and scaling logic
            if (currentMode === 'mobile') {
                targetWidth = 375;
                targetHeight = 812;
                
                // For mobile, scale by height to fit the screen
                scale = Math.min(availableHeight / targetHeight, availableWidth / targetWidth);
                if (scale > 1) scale = 1; 
                
                scaleContainer.style.transformOrigin = 'top left';
                
                // Add device styling
                iframe.className = "bg-white shadow-[0_0_0_12px_#1e293b,0_20px_25px_-5px_rgb(0,0,0,0.1),0_8px_10px_-6px_rgb(0,0,0,0.1)] overflow-y-auto block w-full rounded-[2.5rem] transition-all duration-300";
                
            } else if (currentMode === 'tablet') {
                targetWidth = 768;
                targetHeight = 1024;
                
                // For tablet, scale by both width and height to prevent cropping
                scale = Math.min(availableHeight / targetHeight, availableWidth / targetWidth);
                if (scale > 1) scale = 1;
                
                scaleContainer.style.transformOrigin = 'top left';
                
                // Add device styling
                iframe.className = "bg-white shadow-[0_0_0_12px_#1e293b,0_20px_25px_-5px_rgb(0,0,0,0.1),0_8px_10px_-6px_rgb(0,0,0,0.1)] overflow-y-auto block w-full rounded-[1.5rem] transition-all duration-300";
                
            } else { // desktop
                targetWidth = 1280; // Standard minimal desktop size
                
                // For desktop, scale down so the 1280px width fits into the preview column
                scale = availableWidth / targetWidth;
                if (scale > 1) scale = 1;
                
                // Calculate virtual height so it touches the bottom perfectly after scaling
                targetHeight = availableHeight / scale;
                
                // Set origin to top-left to ensure it flushes perfectly against the top and left borders
                scaleContainer.style.transformOrigin = 'top left';
                
                // Minimal styling for desktop (full bleed)
                iframe.className = "bg-white overflow-y-auto block w-full transition-all duration-300 border-none rounded-none";
            }
            
            // Apply dimensions to iframe
            iframe.style.width = targetWidth + 'px';
            iframe.style.height = targetHeight + 'px';
            
            // Apply scale to the container holding the iframe
            scaleContainer.style.transform = `scale(${scale})`;
            scaleContainer.style.width = `${targetWidth * scale}px`;
            scaleContainer.style.height = `${targetHeight * scale}px`;
        }

        function setPreviewMode(mode) {
            currentMode = mode;
            const container = document.getElementById('preview-container');
            const buttons = document.querySelectorAll('.preview-mode-btn');
            
            // Reset state
            buttons.forEach(btn => {
                btn.classList.remove('active-mode', 'text-blue-600', 'bg-white', 'shadow-sm', 'border-slate-200');
                btn.classList.add('text-slate-500', 'border-transparent');
            });

            // Set active button
            const activeBtn = document.getElementById(`btn-mode-${mode}`);
            if (activeBtn) {
                activeBtn.classList.remove('text-slate-500', 'border-transparent');
                activeBtn.classList.add('active-mode', 'text-blue-600', 'bg-white', 'shadow-sm', 'border-slate-200');
            }

            // Adjust outer container width just slightly to hint at device size, 
            // but keep it flexible to not break layout.
            if (mode === 'mobile') {
                container.style.width = '400px';
                container.style.maxWidth = '100%';
            } else { 
                // tablet & desktop - reset inline styles to let Tailwind CSS breakpoints handle it
                container.style.width = ''; 
                container.style.maxWidth = '';
            }

            // Small delay to allow CSS width transition of container before scaling
            setTimeout(applyScale, 310); // 300ms is the duration-300 transition class
        }

        // Initialize on load and on window resize
        window.addEventListener('load', () => {
            setPreviewMode('desktop');
            applyScale();
        });
        window.addEventListener('resize', applyScale);
    </script>