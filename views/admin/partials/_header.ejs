<header class="h-14 lg:h-16 bg-white border-b border-slate-200 flex items-center justify-between px-3 lg:px-6 sticky top-0 z-40 shadow-sm">
    <div class="flex items-center gap-2 lg:gap-4">
        <button onclick="toggleMobileSidebar()" class="lg:hidden p-1.5 lg:p-2 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors">
            <span class="material-icons text-lg lg:text-xl">menu</span>
        </button>
        <h1 class="text-sm lg:text-lg font-semibold text-slate-800"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
    </div>
    <div class="flex items-center gap-1 lg:gap-3">
        <div class="hidden sm:block relative">
            <span class="material-icons absolute left-2.5 lg:left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
            <input type="text" placeholder="Search..." class="pl-9 lg:pl-10 pr-3 lg:pr-4 py-1.5 lg:py-2 w-40 lg:w-64 bg-slate-50 border border-slate-200 rounded-lg lg:rounded-xl text-xs lg:text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
        </div>
        <button class="p-1.5 lg:p-2 rounded-lg lg:rounded-xl text-slate-500 hover:bg-slate-100 transition-colors relative">
            <span class="material-icons text-lg lg:text-xl">notifications</span>
            <span class="absolute top-0.5 lg:top-1 right-0.5 lg:right-1 w-1.5 lg:w-2 h-1.5 lg:h-2 bg-red-500 rounded-full"></span>
        </button>
        <div class="lg:hidden flex items-center gap-2">
            <% if (typeof user !== 'undefined' && user && user.avatar_url) { %>
                <img src="<%= user.avatar_url %>" alt="Avatar" class="w-7 lg:w-8 h-7 lg:h-8 rounded-full object-cover">
            <% } else { %>
                <span class="material-icons text-slate-600">account_circle</span>
            <% } %>
        </div>
    </div>
</header>