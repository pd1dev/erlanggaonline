<% allIcons = iconCategories.flatMap(c => c.icons); %>

<div class="icon-select-container relative" data-name="<%= name %>">
    <input type="hidden" name="<%= name %>" id="<%= name %>" value="<%= value || '' %>">
    <% if (linkedInput) { %>
    <input type="hidden" name="<%= linkedInput %>" id="<%= linkedInput %>-<%= name %>" value="<%= value || '' %>">
    <% } %>
    
    <button type="button" class="icon-select-trigger w-full border border-gray-300 rounded-lg px-3 py-2 text-sm flex items-center justify-between gap-2 bg-white hover:bg-gray-50 transition-colors" onclick="toggleIconDropdown('<%= name %>')">
        <span class="flex items-center gap-2">
            <% if (value && allIcons.includes(value)) { %>
                <span class="material-icons text-blue-600"><%= value %></span>
                <span class="text-gray-700 font-medium"><%= value %></span>
            <% } else { %>
                <span class="material-icons text-gray-400">image</span>
                <span class="text-gray-400">Pilih icon...</span>
            <% } %>
        </span>
        <span class="material-icons text-gray-400 transition-transform" id="icon-arrow-<%= name %>">expand_more</span>
    </button>
    
    <div id="dropdown-<%= name %>" class="icon-select-dropdown hidden absolute z-50 mt-1 w-96 bg-white border border-gray-200 rounded-xl shadow-xl">
        <!-- Search -->
        <div class="p-3 border-b border-gray-100">
            <div class="relative">
                <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">search</span>
                <input type="text" 
                    placeholder="Cari icon..." 
                    class="w-full pl-9 pr-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
                    onkeyup="filterIcons('<%= name %>', this.value)">
            </div>
        </div>
        
        <!-- Icon Grid with Categories -->
        <div class="max-h-80 overflow-y-auto" id="icon-grid-<%= name %>">
            <% iconCategories.forEach((category, catIdx) => { %>
                <div class="icon-category" data-category="<%= category.name.toLowerCase() %>">
                    <div class="px-3 py-2 bg-gray-50 border-y border-gray-100 sticky top-0">
                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= category.name %></p>
                    </div>
                    <div class="p-2">
                        <div class="grid grid-cols-6 gap-1">
                            <% category.icons.forEach(icon => { %>
                                <button type="button" 
                                    class="icon-option p-2 rounded-lg hover:bg-blue-50 flex items-center justify-center transition-all <%= value === icon ? 'bg-blue-100 ring-2 ring-blue-500' : '' %>"
                                    onclick="selectIcon('<%= name %>', '<%= icon %>'<%= linkedInput ? ', ' + "'" + linkedInput + "'" : '' %>)"
                                    title="<%= icon %>"
                                    data-icon="<%= icon %>">
                                    <span class="material-icons <%= value === icon ? 'text-blue-600' : 'text-gray-600' %>"><%= icon %></span>
                                </button>
                            <% }); %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
        
        <!-- Footer -->
        <div class="p-2 border-t border-gray-100 bg-gray-50 rounded-b-xl">
            <p class="text-xs text-gray-400 text-center"><%= allIcons.length %> icon tersedia</p>
        </div>
    </div>
</div>

<script>
    function toggleIconDropdown(name) {
        const dropdown = document.getElementById('dropdown-' + name);
        const arrow = document.getElementById('icon-arrow-' + name);
        dropdown.classList.toggle('hidden');
        
        if (!dropdown.classList.contains('hidden')) {
            arrow.style.transform = 'rotate(180deg)';
            // Focus search input
            setTimeout(() => {
                dropdown.querySelector('input[type="text"]').focus();
            }, 100);
        } else {
            arrow.style.transform = 'rotate(0deg)';
        }
        
        document.querySelectorAll('.icon-select-dropdown').forEach(d => {
            if (d.id !== 'dropdown-' + name) {
                d.classList.add('hidden');
                const dArrow = document.getElementById('icon-arrow-' + d.id.replace('dropdown-', ''));
                if (dArrow) dArrow.style.transform = 'rotate(0deg)';
            }
        });
    }

    function filterIcons(name, search) {
        const grid = document.getElementById('icon-grid-' + name);
        const searchLower = search.toLowerCase();
        
        if (!searchLower) {
            // Show all categories
            grid.querySelectorAll('.icon-category').forEach(cat => {
                cat.classList.remove('hidden');
            });
            return;
        }
        
        // Filter icons
        grid.querySelectorAll('.icon-option').forEach(btn => {
            const icon = btn.getAttribute('data-icon').toLowerCase();
            if (icon.includes(searchLower)) {
                btn.classList.remove('hidden');
            } else {
                btn.classList.add('hidden');
            }
        });
        
        // Hide empty categories
        grid.querySelectorAll('.icon-category').forEach(cat => {
            const visibleIcons = cat.querySelectorAll('.icon-option:not(.hidden)');
            if (visibleIcons.length === 0) {
                cat.classList.add('hidden');
            } else {
                cat.classList.remove('hidden');
            }
        });
    }

    function selectIcon(name, icon, linkedInput) {
        document.getElementById(name).value = icon;
        if (linkedInput) {
            document.getElementById(linkedInput + '-' + name).value = icon;
        }
        
        const container = document.querySelector(`[data-name="${name}"]`);
        const trigger = container.querySelector('.icon-select-trigger');
        trigger.innerHTML = `
            <span class="flex items-center gap-2">
                <span class="material-icons text-blue-600">${icon}</span>
                <span class="text-gray-700 font-medium">${icon}</span>
            </span>
            <span class="material-icons text-gray-400 transition-transform" id="icon-arrow-${name}">expand_more</span>
        `;
        
        container.querySelectorAll('.icon-option').forEach(btn => {
            btn.classList.remove('bg-blue-100', 'ring-2', 'ring-blue-500');
            btn.querySelector('span').classList.remove('text-blue-600');
            btn.querySelector('span').classList.add('text-gray-600');
        });
        
        const selectedBtn = container.querySelector(`[data-icon="${icon}"]`);
        if (selectedBtn) {
            selectedBtn.classList.add('bg-blue-100', 'ring-2', 'ring-blue-500');
            selectedBtn.querySelector('span').classList.remove('text-gray-600');
            selectedBtn.querySelector('span').classList.add('text-blue-600');
        }
        
        document.getElementById('dropdown-' + name).classList.add('hidden');
        document.getElementById('icon-arrow-' + name).style.transform = 'rotate(0deg)';
    }

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.icon-select-container')) {
            document.querySelectorAll('.icon-select-dropdown').forEach(d => {
                d.classList.add('hidden');
                const dArrow = document.getElementById('icon-arrow-' + d.id.replace('dropdown-', ''));
                if (dArrow) dArrow.style.transform = 'rotate(0deg)';
            });
        }
    });
</script>
