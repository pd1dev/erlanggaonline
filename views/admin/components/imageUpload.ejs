<div class="space-y-2">
    <input type="file" name="<%= name %>" id="<%= name %>" 
        accept="image/jpeg,image/jpg,image/png,image/gif,image/webp"
        onchange="validateAndPreviewImage(this, '<%= previewId || name %>')"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-blue-50 file:text-blue-600 file:font-semibold file:cursor-pointer hover:file:bg-blue-100 transition-colors">
    <p class="text-xs text-gray-400">Format: JPG, PNG, GIF, WEBP. Maks 5MB. Otomatis resize jika > 1MB.</p>
    <p id="<%= name %>-error" class="text-xs text-red-500 hidden"></p>
    <% if (existingUrl) { %>
        <div class="mt-2">
            <p class="text-xs text-gray-500 mb-1">Gambar saat ini:</p>
            <img id="<%= previewId || name %>" src="<%= existingUrl %>" 
                class="w-32 h-32 object-cover rounded-lg border border-gray-200 shadow-sm"
                onerror="this.src='/placeholder-image.jpg'">
        </div>
    <% } else { %>
        <img id="<%= previewId || name %>" class="w-32 h-32 object-cover rounded-lg border border-gray-200 hidden">
    <% } %>
</div>

<script>
    const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB
    const ALLOWED_TYPES = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];

    function validateAndPreviewImage(input, previewId) {
        const errorEl = document.getElementById(input.name + '-error');
        const preview = document.getElementById(previewId);
        
        // Reset error
        if (errorEl) {
            errorEl.classList.add('hidden');
            errorEl.textContent = '';
        }

        if (!input.files || !input.files[0]) {
            if (preview) preview.classList.add('hidden');
            return true;
        }

        const file = input.files[0];

        // Validate file type
        if (!ALLOWED_TYPES.includes(file.type)) {
            if (errorEl) {
                errorEl.textContent = 'File harus berupa gambar (JPG, PNG, GIF, WEBP)';
                errorEl.classList.remove('hidden');
            }
            input.value = '';
            if (preview) preview.classList.add('hidden');
            return false;
        }

        // Validate file size (max 5MB)
        if (file.size > MAX_FILE_SIZE) {
            if (errorEl) {
                errorEl.textContent = 'Ukuran file maksimal 5MB';
                errorEl.classList.remove('hidden');
            }
            input.value = '';
            if (preview) preview.classList.add('hidden');
            return false;
        }

        // Show preview
        if (preview) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }

        return true;
    }
</script>
